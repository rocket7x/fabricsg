{% doc %}
  @prompt
    can i have a section with subheader, header, and preheader with 4 blocks that include headers and descriptions and if i can customize the colors of the sections as well, if i can have 2 blocks per row
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.section_background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-content-section__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-content-section__preheader-{{ ai_gen_id }} {
    font-size: {{ block.settings.preheader_font_size }}px;
    color: {{ block.settings.preheader_color }};
    margin-bottom: {{ block.settings.preheader_margin_bottom }}px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-content-section__header-{{ ai_gen_id }} {
    font-size: {{ block.settings.header_font_size }}px;
    color: {{ block.settings.header_color }};
    margin-bottom: {{ block.settings.header_margin_bottom }}px;
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-content-section__subheader-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheader_font_size }}px;
    color: {{ block.settings.subheader_color }};
    margin-bottom: {{ block.settings.subheader_margin_bottom }}px;
    font-weight: 400;
    line-height: 1.5;
  }

  .ai-content-section__blocks-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.blocks_gap }}px;
    margin-top: {{ block.settings.blocks_margin_top }}px;
  }

  .ai-content-section__block-{{ ai_gen_id }} {
    background-color: {{ block.settings.block_background_color }};
    padding: {{ block.settings.block_padding }}px;
    border-radius: {{ block.settings.block_border_radius }}px;
    border: {{ block.settings.block_border_width }}px solid {{ block.settings.block_border_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-content-section__block-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
  }

  .ai-content-section__block-header-{{ ai_gen_id }} {
    font-size: {{ block.settings.block_header_font_size }}px;
    color: {{ block.settings.block_header_color }};
    margin-bottom: {{ block.settings.block_header_margin_bottom }}px;
    font-weight: 600;
    line-height: 1.3;
  }

  .ai-content-section__block-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.block_description_font_size }}px;
    color: {{ block.settings.block_description_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .ai-content-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 15px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-content-section__blocks-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.blocks_gap | times: 0.8 }}px;
    }

    .ai-content-section__header-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_font_size | times: 0.8 }}px;
    }

    .ai-content-section__preheader-{{ ai_gen_id }} {
      font-size: {{ block.settings.preheader_font_size | times: 0.9 }}px;
    }

    .ai-content-section__subheader-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheader_font_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-content-section__blocks-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<div class="ai-content-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-section__container-{{ ai_gen_id }}">
    {% if block.settings.preheader != blank %}
      <div class="ai-content-section__preheader-{{ ai_gen_id }}">
        {{ block.settings.preheader }}
      </div>
    {% endif %}

    {% if block.settings.header != blank %}
      <h2 class="ai-content-section__header-{{ ai_gen_id }}">
        {{ block.settings.header }}
      </h2>
    {% endif %}

    {% if block.settings.subheader != blank %}
      <div class="ai-content-section__subheader-{{ ai_gen_id }}">
        {{ block.settings.subheader }}
      </div>
    {% endif %}

    <div class="ai-content-section__blocks-{{ ai_gen_id }}">
      {% if block.settings.block_1_header != blank or block.settings.block_1_description != blank %}
        <div class="ai-content-section__block-{{ ai_gen_id }}">
          {% if block.settings.block_1_header != blank %}
            <h3 class="ai-content-section__block-header-{{ ai_gen_id }}">
              {{ block.settings.block_1_header }}
            </h3>
          {% endif %}
          {% if block.settings.block_1_description != blank %}
            <div class="ai-content-section__block-description-{{ ai_gen_id }}">
              {{ block.settings.block_1_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.block_2_header != blank or block.settings.block_2_description != blank %}
        <div class="ai-content-section__block-{{ ai_gen_id }}">
          {% if block.settings.block_2_header != blank %}
            <h3 class="ai-content-section__block-header-{{ ai_gen_id }}">
              {{ block.settings.block_2_header }}
            </h3>
          {% endif %}
          {% if block.settings.block_2_description != blank %}
            <div class="ai-content-section__block-description-{{ ai_gen_id }}">
              {{ block.settings.block_2_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.block_3_header != blank or block.settings.block_3_description != blank %}
        <div class="ai-content-section__block-{{ ai_gen_id }}">
          {% if block.settings.block_3_header != blank %}
            <h3 class="ai-content-section__block-header-{{ ai_gen_id }}">
              {{ block.settings.block_3_header }}
            </h3>
          {% endif %}
          {% if block.settings.block_3_description != blank %}
            <div class="ai-content-section__block-description-{{ ai_gen_id }}">
              {{ block.settings.block_3_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.block_4_header != blank or block.settings.block_4_description != blank %}
        <div class="ai-content-section__block-{{ ai_gen_id }}">
          {% if block.settings.block_4_header != blank %}
            <h3 class="ai-content-section__block-header-{{ ai_gen_id }}">
              {{ block.settings.block_4_header }}
            </h3>
          {% endif %}
          {% if block.settings.block_4_description != blank %}
            <div class="ai-content-section__block-description-{{ ai_gen_id }}">
              {{ block.settings.block_4_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

