{% doc %}
  @prompt
    can i have a section with subheader, header, and preheader with 5 blocks that include adjustable line weight headers and descriptions and if i can customize the colors of the sections as well, if i can have 3 blocks per row
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-content-section__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-content-section__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-content-section__preheader-{{ ai_gen_id }} {
    font-size: {{ block.settings.preheader_size }}px;
    color: {{ block.settings.preheader_color }};
    margin-bottom: 8px;
    font-weight: {{ block.settings.preheader_weight }};
    line-height: 1.4;
  }

  .ai-content-section__main-header-{{ ai_gen_id }} {
    font-size: {{ block.settings.header_size }}px;
    color: {{ block.settings.header_color }};
    margin-bottom: 12px;
    font-weight: {{ block.settings.header_weight }};
    line-height: 1.2;
  }

  .ai-content-section__subheader-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheader_size }}px;
    color: {{ block.settings.subheader_color }};
    margin-bottom: 0;
    font-weight: {{ block.settings.subheader_weight }};
    line-height: 1.5;
  }

  .ai-content-section__blocks-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: {{ block.settings.block_spacing }}px;
    margin-top: {{ block.settings.content_spacing }}px;
  }

  .ai-content-block-{{ ai_gen_id }} {
    background-color: {{ block.settings.block_background_color }};
    padding: {{ block.settings.block_padding }}px;
    border-radius: {{ block.settings.block_border_radius }}px;
    border: {{ block.settings.block_border_width }}px solid {{ block.settings.block_border_color }};
    text-align: {{ block.settings.block_text_alignment }};
  }

  .ai-content-block__header-{{ ai_gen_id }} {
    font-size: {{ block.settings.block_header_size }}px;
    color: {{ block.settings.block_header_color }};
    margin-bottom: {{ block.settings.block_header_spacing }}px;
    font-weight: {{ block.settings.block_header_weight }};
    line-height: 1.3;
  }

  .ai-content-block__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.block_description_size }}px;
    color: {{ block.settings.block_description_color }};
    margin-bottom: 0;
    font-weight: {{ block.settings.block_description_weight }};
    line-height: 1.6;
  }

  @media screen and (max-width: 768px) {
    .ai-content-section__blocks-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.block_spacing | times: 0.75 }}px;
    }

    .ai-content-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.75 }}px 16px {{ block.settings.section_padding_bottom | times: 0.75 }}px;
    }

    .ai-content-section__main-header-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_size | times: 0.85 }}px;
    }

    .ai-content-section__preheader-{{ ai_gen_id }} {
      font-size: {{ block.settings.preheader_size | times: 0.9 }}px;
    }

    .ai-content-section__subheader-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheader_size | times: 0.9 }}px;
    }
  }

  @media screen and (min-width: 769px) and (max-width: 1024px) {
    .ai-content-section__blocks-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1025px) {
    .ai-content-section__blocks-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }
{% endstyle %}

<div class="ai-content-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-section__container-{{ ai_gen_id }}">
    {% if block.settings.show_header_section %}
      <div class="ai-content-section__header-{{ ai_gen_id }}">
        {% if block.settings.preheader != blank %}
          <div class="ai-content-section__preheader-{{ ai_gen_id }}">
            {{ block.settings.preheader }}
          </div>
        {% endif %}

        {% if block.settings.main_header != blank %}
          <h2 class="ai-content-section__main-header-{{ ai_gen_id }}">
            {{ block.settings.main_header }}
          </h2>
        {% endif %}

        {% if block.settings.subheader != blank %}
          <div class="ai-content-section__subheader-{{ ai_gen_id }}">
            {{ block.settings.subheader }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-content-section__blocks-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign block_enabled_key = 'block_' | append: i | append: '_enabled'
          assign block_header_key = 'block_' | append: i | append: '_header'
          assign block_description_key = 'block_' | append: i | append: '_description'

          assign block_enabled = block.settings[block_enabled_key]
          assign block_header = block.settings[block_header_key]
          assign block_description = block.settings[block_description_key]
        %}

        {% if block_enabled %}
          <div class="ai-content-block-{{ ai_gen_id }}">
            {% if block_header != blank %}
              <h3 class="ai-content-block__header-{{ ai_gen_id }}">
                {{ block_header }}
              </h3>
            {% endif %}

            {% if block_description != blank %}
              <div class="ai-content-block__description-{{ ai_gen_id }}">
                {{ block_description }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

