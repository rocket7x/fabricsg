{% doc %}
  @prompt
    can i have a section with subheader, header, and preheader with 4 blocks that include adjustable line weight headers and descriptions and if i can customize the colors of the sections as well, if i can have 2 blocks per row, can i have a section with subheader, header, and preheader with 4 blocks that include adjustable line weight headers and descriptions and if i can customize the colors of the sections as well, if i can have 2 blocks per row
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.section_background_color }};
  }

  .ai-content-section-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-content-section-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-content-section-preheader-{{ ai_gen_id }} {
    font-size: {{ block.settings.preheader_size }}px;
    color: {{ block.settings.preheader_color }};
    margin-bottom: 8px;
    font-weight: {{ block.settings.preheader_weight }};
    line-height: 1.4;
  }

  .ai-content-section-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.header_size }}px;
    color: {{ block.settings.header_color }};
    margin: 0 0 12px;
    font-weight: {{ block.settings.header_weight }};
    line-height: 1.2;
  }

  .ai-content-section-subheader-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheader_size }}px;
    color: {{ block.settings.subheader_color }};
    margin: 0;
    font-weight: {{ block.settings.subheader_weight }};
    line-height: 1.5;
  }

  .ai-content-blocks-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.block_spacing }}px;
    margin-top: {{ block.settings.blocks_top_spacing }}px;
  }

  .ai-content-block-{{ ai_gen_id }} {
    background-color: {{ block.settings.block_background_color }};
    padding: {{ block.settings.block_padding }}px;
    border-radius: {{ block.settings.block_border_radius }}px;
    text-align: {{ block.settings.block_text_alignment }};
    border: {{ block.settings.block_border_width }}px solid {{ block.settings.block_border_color }};
  }

  .ai-content-block-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.block_title_size }}px;
    color: {{ block.settings.block_title_color }};
    margin: 0 0 12px;
    font-weight: {{ block.settings.block_title_weight }};
    line-height: 1.3;
  }

  .ai-content-block-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.block_description_size }}px;
    color: {{ block.settings.block_description_color }};
    margin: 0;
    font-weight: {{ block.settings.block_description_weight }};
    line-height: 1.6;
  }

  @media screen and (max-width: 768px) {
    .ai-content-blocks-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.block_spacing | divided_by: 1.5 }}px;
    }

    .ai-content-section-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_size | times: 0.8 }}px;
    }

    .ai-content-section-preheader-{{ ai_gen_id }} {
      font-size: {{ block.settings.preheader_size | times: 0.9 }}px;
    }

    .ai-content-section-subheader-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheader_size | times: 0.9 }}px;
    }

    .ai-content-block-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.block_title_size | times: 0.9 }}px;
    }

    .ai-content-block-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.block_description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-content-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-section-container-{{ ai_gen_id }}">
    {% if block.settings.preheader != blank or block.settings.header != blank or block.settings.subheader != blank %}
      <div class="ai-content-section-header-{{ ai_gen_id }}">
        {% if block.settings.preheader != blank %}
          <div class="ai-content-section-preheader-{{ ai_gen_id }}">
            {{ block.settings.preheader }}
          </div>
        {% endif %}

        {% if block.settings.header != blank %}
          <h2 class="ai-content-section-title-{{ ai_gen_id }}">
            {{ block.settings.header }}
          </h2>
        {% endif %}

        {% if block.settings.subheader != blank %}
          <div class="ai-content-section-subheader-{{ ai_gen_id }}">
            {{ block.settings.subheader }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-content-blocks-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign block_title_key = 'block_' | append: i | append: '_title'
          assign block_description_key = 'block_' | append: i | append: '_description'
          assign block_title = block.settings[block_title_key]
          assign block_description = block.settings[block_description_key]
        %}

        {% if block_title != blank or block_description != blank %}
          <div class="ai-content-block-{{ ai_gen_id }}">
            {% if block_title != blank %}
              <h3 class="ai-content-block-title-{{ ai_gen_id }}">
                {{ block_title }}
              </h3>
            {% endif %}

            {% if block_description != blank %}
              <div class="ai-content-block-description-{{ ai_gen_id }}">
                {{ block_description }}
              </div>
            {% endif %}
          </div>
        {% else %}
          <div class="ai-content-block-{{ ai_gen_id }}">
            <h3 class="ai-content-block-title-{{ ai_gen_id }}">
              Block {{ i }} title
            </h3>
            <div class="ai-content-block-description-{{ ai_gen_id }}">
              Add your content for block {{ i }} here. Customize the title and description in the block settings.
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

