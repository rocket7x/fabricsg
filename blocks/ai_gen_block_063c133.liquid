{% doc %}
  @prompt
    image on the right with a buy more save more deal section for Flat 10% OFF on order above $100 on the left and i would like to adjust the line weight of the header text and button text. as well as move the alignment on mobile, can the image show first on mobile, I WANT THE TEXT TO SHOW BELOW THE IMAGE/CONTENT ON MOBILE
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-deal-section-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 40px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    max-width: 100%;
  }

  .ai-deal-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-deal-header-{{ ai_gen_id }} {
    color: {{ block.settings.header_color }};
    font-size: {{ block.settings.header_size }}px;
    font-weight: {{ block.settings.header_weight }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-deal-subheader-{{ ai_gen_id }} {
    color: {{ block.settings.subheader_color }};
    font-size: {{ block.settings.subheader_size }}px;
    margin: 0;
    line-height: 1.4;
  }

  .ai-deal-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .ai-deal-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 30px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: 2px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: {{ block.settings.button_text_weight }};
    transition: all 0.3s ease;
    cursor: pointer;
    align-self: flex-start;
  }

  .ai-deal-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-deal-image-wrapper-{{ ai_gen_id }} {
    flex: 1;
    max-width: 50%;
  }

  .ai-deal-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-deal-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 300px;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-deal-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.5;
  }

  .ai-deal-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 768px) {
    .ai-deal-section-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      gap: 20px;
      padding: 20px;
      text-align: {{ block.settings.mobile_alignment }};
    }

    .ai-deal-image-wrapper-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-deal-button-{{ ai_gen_id }} {
      {% if block.settings.mobile_alignment == 'center' %}
        align-self: center;
      {% elsif block.settings.mobile_alignment == 'right' %}
        align-self: flex-end;
      {% else %}
        align-self: flex-start;
      {% endif %}
    }
  }
{% endstyle %}

<div
  class="ai-deal-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-deal-content-{{ ai_gen_id }}">
    {% if block.settings.header_text != blank %}
      <h2 class="ai-deal-header-{{ ai_gen_id }}">{{ block.settings.header_text }}</h2>
    {% endif %}

    {% if block.settings.subheader_text != blank %}
      <h3 class="ai-deal-subheader-{{ ai_gen_id }}">{{ block.settings.subheader_text }}</h3>
    {% endif %}

    {% if block.settings.description_text != blank %}
      <div class="ai-deal-description-{{ ai_gen_id }}">{{ block.settings.description_text }}</div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-deal-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>

  <div class="ai-deal-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.deal_image %}
      <img
        src="{{ block.settings.deal_image | image_url: width: 800 }}"
        alt="{{ block.settings.deal_image.alt | escape }}"
        class="ai-deal-image-{{ ai_gen_id }}"
        loading="lazy"
        width="{{ block.settings.deal_image.width }}"
        height="{{ block.settings.deal_image.height }}"
      >
    {% else %}
      <div class="ai-deal-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-deal-empty-state-{{ ai_gen_id }}">
          Add an image to complete your deal section
        </div>
      </div>
    {% endif %}
  </div>
</div>

