      "default": 20
    },
    {
      "type": "header",
      "content": "Mobile spacing"
    },
    {
      "type": "range",
      "id": "mobile_space_above",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Space above button",
      "default": 15
    },
    {
      "type": "range",
      "id": "mobile_space_below",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Space below button",
