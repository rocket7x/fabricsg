{% doc %}
  @prompt
    can you create a custom button with ability to adjust padding on top and bottom, can you ad adjustment to desktop padding, not the button padding but the space above and below the button i want to adjust
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-button-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.button_alignment }};
    width: 100%;
    padding-top: {{ block.settings.desktop_space_above }}px;
    padding-bottom: {{ block.settings.desktop_space_below }}px;
  }

  .ai-custom-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    font-size: {{ block.settings.desktop_font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: {{ block.settings.font_family }};
    text-transform: {{ block.settings.text_transform }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    min-height: 44px;
    box-sizing: border-box;
    padding: {{ block.settings.button_padding_top }}px {{ block.settings.button_padding_horizontal }}px {{ block.settings.button_padding_bottom }}px {{ block.settings.button_padding_horizontal }}px;
  }

  .ai-custom-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.border_hover_color }};
    transform: translateY({{ block.settings.hover_transform }}px);
  }

  .ai-custom-button-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_color }};
    outline-offset: 2px;
  }

  {% if block.settings.full_width %}
    .ai-custom-button-{{ ai_gen_id }} {
      width: 100%;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-custom-button-wrapper-{{ ai_gen_id }} {
      padding-top: {{ block.settings.mobile_space_above }}px;
      padding-bottom: {{ block.settings.mobile_space_below }}px;
    }

    .ai-custom-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_font_size }}px;
    }
  }
{% endstyle %}

<div class="ai-custom-button-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.button_link != blank %}
    <a
      href="{{ block.settings.button_link }}"
      class="ai-custom-button-{{ ai_gen_id }}"
      {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
    >
      {{ block.settings.button_text }}
    </a>
  {% else %}
    <button
      type="button"
      class="ai-custom-button-{{ ai_gen_id }}"
    >
      {{ block.settings.button_text }}
    </button>
  {% endif %}
</div>

{% schema %}
