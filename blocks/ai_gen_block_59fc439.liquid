{% doc %}
  @prompt
    a customizable button with adjustable padding above and below the button, perfect! can i change the section background color too
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-button-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_background_color }};
    width: 100%;
  }

  .ai-custom-button-wrapper-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-custom-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-decoration: none;
    text-transform: {{ block.settings.text_transform }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: {{ block.settings.min_width }}px;
    max-width: 100%;
    box-sizing: border-box;
  }

  .ai-custom-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.hover_border_color }};
    transform: translateY({{ block.settings.hover_transform }}px);
  }

  .ai-custom-button-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_background_color }};
    outline-offset: 2px;
  }

  @media screen and (max-width: 749px) {
    .ai-custom-button-wrapper-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top | times: 0.7 | round }}px;
      padding-bottom: {{ block.settings.padding_bottom | times: 0.7 | round }}px;
    }

    .ai-custom-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 | round }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.8 | round }}px {{ block.settings.button_padding_horizontal | times: 0.8 | round }}px;
    }
  }
{% endstyle %}

<div
  class="ai-custom-button-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-custom-button-wrapper-{{ ai_gen_id }}">
    {% if block.settings.button_link != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-custom-button-{{ ai_gen_id }}"
        {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
      >
        {{ block.settings.button_text }}
      </a>
    {% else %}
      <button
        type="button"
        class="ai-custom-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </button>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Customizable button",
  "settings": [
    {
      "type": "header",
      "content": "Section style"
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Section background color",
