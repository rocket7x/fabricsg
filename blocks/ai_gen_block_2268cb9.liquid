{% doc %}
  @prompt
    can i have 5 multicolumn icon and texts for: timeless, 100% cotton, zipper, long-lasting, and heart, can i adjust the line weight of the icons and change the 100% cotton icon to a leaf, zipper icon to a zipper, and long-lasting to something different
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multicolumn-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-multicolumn-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-multicolumn-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: {{ block.settings.column_gap }}px;
    align-items: start;
  }

  .ai-multicolumn-item-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-multicolumn-item-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
  }

  .ai-multicolumn-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_margin_bottom }}px;
    color: {{ block.settings.icon_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-multicolumn-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke-width: {{ block.settings.icon_stroke_width }};
  }

  .ai-multicolumn-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    text-transform: {{ block.settings.title_text_transform }};
    font-family: var(--heading-font-family);
  }

  .ai-multicolumn-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_font_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
    font-family: var(--font-family);
  }

  @media screen and (max-width: 990px) {
    .ai-multicolumn-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-multicolumn-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-multicolumn-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-multicolumn-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.9 }}px;
    }

    .ai-multicolumn-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-multicolumn-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-multicolumn-container-{{ ai_gen_id }}">
    <div class="ai-multicolumn-grid-{{ ai_gen_id }}">
      <div class="ai-multicolumn-item-{{ ai_gen_id }}">
        <div class="ai-multicolumn-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12,6 12,12 16,14"/>
          </svg>
        </div>
        <h3 class="ai-multicolumn-title-{{ ai_gen_id }}">{{ block.settings.column_1_title }}</h3>
        <p class="ai-multicolumn-text-{{ ai_gen_id }}">{{ block.settings.column_1_text }}</p>
      </div>

      <div class="ai-multicolumn-item-{{ ai_gen_id }}">
        <div class="ai-multicolumn-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
            <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
          </svg>
        </div>
        <h3 class="ai-multicolumn-title-{{ ai_gen_id }}">{{ block.settings.column_2_title }}</h3>
        <p class="ai-multicolumn-text-{{ ai_gen_id }}">{{ block.settings.column_2_text }}</p>
      </div>

      <div class="ai-multicolumn-item-{{ ai_gen_id }}">
        <div class="ai-multicolumn-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v20"/>
            <path d="m8 8 4-4 4 4"/>
            <path d="m8 16 4 4 4-4"/>
          </svg>
        </div>
        <h3 class="ai-multicolumn-title-{{ ai_gen_id }}">{{ block.settings.column_3_title }}</h3>
        <p class="ai-multicolumn-text-{{ ai_gen_id }}">{{ block.settings.column_3_text }}</p>
      </div>

      <div class="ai-multicolumn-item-{{ ai_gen_id }}">
        <div class="ai-multicolumn-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
        </div>
        <h3 class="ai-multicolumn-title-{{ ai_gen_id }}">{{ block.settings.column_4_title }}</h3>
        <p class="ai-multicolumn-text-{{ ai_gen_id }}">{{ block.settings.column_4_text }}</p>
      </div>

      <div class="ai-multicolumn-item-{{ ai_gen_id }}">
        <div class="ai-multicolumn-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </div>
        <h3 class="ai-multicolumn-title-{{ ai_gen_id }}">{{ block.settings.column_5_title }}</h3>
        <p class="ai-multicolumn-text-{{ ai_gen_id }}">{{ block.settings.column_5_text }}</p>
      </div>
    </div>
  </div>
</div>

