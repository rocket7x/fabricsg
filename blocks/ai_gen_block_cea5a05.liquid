{% doc %}
  @prompt
    image on the left with a buy more save more deal section for Flat 10% OFF on order above $100, i love it, can i adjust the line weight of the header text and button text. as well as move the alignment on mobile to the left, can i have a special offer subheader too
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-deal-section-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 40px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    max-width: 100%;
  }

  .ai-deal-image-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.image_width }}px;
    max-width: 50%;
  }

  .ai-deal-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-deal-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 300px;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-deal-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-deal-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-deal-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-deal-header-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-deal-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-deal-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-deal-special-subheader-{{ ai_gen_id }} {
    font-size: {{ block.settings.special_subheader_size }}px;
    color: {{ block.settings.special_subheader_color }};
    font-weight: {{ block.settings.special_subheader_weight }};
    margin: 0;
    line-height: 1.3;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-deal-offer-{{ ai_gen_id }} {
    background-color: {{ block.settings.offer_bg_color }};
    color: {{ block.settings.offer_text_color }};
    padding: 16px 24px;
    border-radius: {{ block.settings.offer_border_radius }}px;
    text-align: center;
    border: 2px solid {{ block.settings.offer_border_color }};
  }

  .ai-deal-offer-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.offer_text_size }}px;
    font-weight: 600;
    margin: 0;
  }

  .ai-deal-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
  }

  .ai-deal-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 2px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: {{ block.settings.button_text_weight }};
    transition: all 0.3s ease;
    cursor: pointer;
    align-self: flex-start;
  }

  .ai-deal-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 768px) {
    .ai-deal-section-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 24px;
      padding: 24px;
      text-align: {{ block.settings.mobile_alignment }};
    }

    .ai-deal-image-{{ ai_gen_id }} {
      width: 100%;
      max-width: 100%;
    }

    .ai-deal-content-{{ ai_gen_id }} {
      {% if block.settings.mobile_alignment == 'left' %}
        align-items: flex-start;
      {% elsif block.settings.mobile_alignment == 'center' %}
        align-items: center;
      {% else %}
        align-items: flex-end;
      {% endif %}
    }

    .ai-deal-button-{{ ai_gen_id }} {
      {% if block.settings.mobile_alignment == 'left' %}
        align-self: flex-start;
      {% elsif block.settings.mobile_alignment == 'center' %}
        align-self: center;
      {% else %}
        align-self: flex-end;
      {% endif %}
    }

    .ai-deal-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-deal-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-deal-special-subheader-{{ ai_gen_id }} {
      font-size: {{ block.settings.special_subheader_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div
  class="ai-deal-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-deal-image-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 800 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
      >
    {% else %}
      <div class="ai-deal-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-deal-empty-state-{{ ai_gen_id }}">
          Add an image to showcase your deal
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-deal-content-{{ ai_gen_id }}">
    <div class="ai-deal-header-{{ ai_gen_id }}">
      {% if block.settings.special_subheader != blank %}
        <p class="ai-deal-special-subheader-{{ ai_gen_id }}">{{ block.settings.special_subheader }}</p>
      {% endif %}

      {% if block.settings.title != blank %}
        <h2 class="ai-deal-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <p class="ai-deal-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    {% if block.settings.offer_text != blank %}
      <div class="ai-deal-offer-{{ ai_gen_id }}">
        <p class="ai-deal-offer-text-{{ ai_gen_id }}">{{ block.settings.offer_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-deal-description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-deal-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

