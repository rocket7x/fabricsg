{% doc %}
  @prompt
    can i have a section with subheader, header, and preheader with 4 blocks that include adjustable line weight headers and descriptions and if i can customize the colors of the sections as well, if i can have 2 blocks per row, can i have a section with subheader, header, and preheader with 4 blocks that include adjustable line weight headers and descriptions and if i can customize the colors of the sections as well, if i can have 2 blocks per row
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-content-section__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-content-section__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-content-section__preheader-{{ ai_gen_id }} {
    font-size: {{ block.settings.preheader_size }}px;
    color: {{ block.settings.preheader_color }};
    margin-bottom: 8px;
    font-weight: {{ block.settings.preheader_weight }};
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-content-section__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: 1.2;
  }

  .ai-content-section__subheader-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheader_size }}px;
    color: {{ block.settings.subheader_color }};
    margin: 0;
    font-weight: {{ block.settings.subheader_weight }};
    line-height: 1.5;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-content-section__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.content_spacing }}px;
  }

  .ai-content-section__block-{{ ai_gen_id }} {
    background-color: {{ block.settings.block_background_color }};
    padding: {{ block.settings.block_padding }}px;
    border-radius: {{ block.settings.block_border_radius }}px;
    border: {{ block.settings.block_border_width }}px solid {{ block.settings.block_border_color }};
    text-align: {{ block.settings.block_text_alignment }};
  }

  .ai-content-section__block-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.block_heading_size }}px;
    color: {{ block.settings.block_heading_color }};
    margin: 0 0 12px;
    font-weight: {{ block.settings.block_heading_weight }};
    line-height: 1.3;
  }

  .ai-content-section__block-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.block_description_size }}px;
    color: {{ block.settings.block_description_color }};
    margin: 0;
    font-weight: {{ block.settings.block_description_weight }};
    line-height: 1.6;
  }

  @media screen and (max-width: 768px) {
    .ai-content-section__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-content-section__container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .ai-content-section__block-{{ ai_gen_id }} {
      padding: {{ block.settings.block_padding | times: 0.8 }}px;
    }

    .ai-content-section__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-content-section__block-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.block_heading_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-content-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-section__container-{{ ai_gen_id }}">
    {% if block.settings.preheader != blank or block.settings.heading != blank or block.settings.subheader != blank %}
      <div class="ai-content-section__header-{{ ai_gen_id }}">
        {% if block.settings.preheader != blank %}
          <div class="ai-content-section__preheader-{{ ai_gen_id }}">
            {{ block.settings.preheader }}
          </div>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h2 class="ai-content-section__heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.subheader != blank %}
          <div class="ai-content-section__subheader-{{ ai_gen_id }}">
            {{ block.settings.subheader }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-content-section__grid-{{ ai_gen_id }}">
      {% if block.settings.block_1_heading != blank or block.settings.block_1_description != blank %}
        <div class="ai-content-section__block-{{ ai_gen_id }}">
          {% if block.settings.block_1_heading != blank %}
            <h3 class="ai-content-section__block-heading-{{ ai_gen_id }}">
              {{ block.settings.block_1_heading }}
            </h3>
          {% endif %}
          {% if block.settings.block_1_description != blank %}
            <div class="ai-content-section__block-description-{{ ai_gen_id }}">
              {{ block.settings.block_1_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.block_2_heading != blank or block.settings.block_2_description != blank %}
        <div class="ai-content-section__block-{{ ai_gen_id }}">
          {% if block.settings.block_2_heading != blank %}
            <h3 class="ai-content-section__block-heading-{{ ai_gen_id }}">
              {{ block.settings.block_2_heading }}
            </h3>
          {% endif %}
          {% if block.settings.block_2_description != blank %}
            <div class="ai-content-section__block-description-{{ ai_gen_id }}">
              {{ block.settings.block_2_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.block_3_heading != blank or block.settings.block_3_description != blank %}
        <div class="ai-content-section__block-{{ ai_gen_id }}">
          {% if block.settings.block_3_heading != blank %}
            <h3 class="ai-content-section__block-heading-{{ ai_gen_id }}">
              {{ block.settings.block_3_heading }}
            </h3>
          {% endif %}
          {% if block.settings.block_3_description != blank %}
            <div class="ai-content-section__block-description-{{ ai_gen_id }}">
              {{ block.settings.block_3_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.block_4_heading != blank or block.settings.block_4_description != blank %}
        <div class="ai-content-section__block-{{ ai_gen_id }}">
          {% if block.settings.block_4_heading != blank %}
            <h3 class="ai-content-section__block-heading-{{ ai_gen_id }}">
              {{ block.settings.block_4_heading }}
            </h3>
          {% endif %}
          {% if block.settings.block_4_description != blank %}
            <div class="ai-content-section__block-description-{{ ai_gen_id }}">
              {{ block.settings.block_4_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

