{% doc %}
  @prompt
    custom button where i can adjust padding around the button and the section background color
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-button-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_background_color }};
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px {{ block.settings.section_padding_horizontal }}px;
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-custom-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: var({{ block.settings.button_font_family }});
    text-transform: {{ block.settings.button_text_transform }};
    letter-spacing: {{ block.settings.button_letter_spacing }}px;
    min-width: {{ block.settings.button_min_width }}px;
  }

  .ai-custom-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY({{ block.settings.button_hover_transform }}px);
  }

  .ai-custom-button-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_background_color }};
    outline-offset: 2px;
  }

  @media screen and (max-width: 749px) {
    .ai-custom-button-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px {{ block.settings.section_padding_horizontal | times: 0.7 }}px {{ block.settings.section_padding_bottom | times: 0.7 }}px {{ block.settings.section_padding_horizontal | times: 0.7 }}px;
    }

    .ai-custom-button-{{ ai_gen_id }} {
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div
  class="ai-custom-button-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.button_link != blank %}
    <a
      href="{{ block.settings.button_link }}"
      class="ai-custom-button-{{ ai_gen_id }}"
      {% if block.settings.button_link contains 'http' %}
        target="_blank"
        rel="noopener noreferrer"
      {% endif %}
    >
      {{ block.settings.button_text }}
    </a>
  {% else %}
    <button
      class="ai-custom-button-{{ ai_gen_id }}"
      type="button"
    >
      {{ block.settings.button_text }}
    </button>
  {% endif %}
</div>

{% schema %}
{
  "name": "Custom button",
  "settings": [
    {
      "type": "header",
      "content": "Button content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
