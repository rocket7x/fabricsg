{% doc %}
  @prompt
    can i have a section with subheader, header, and preheader with 4 blocks that include adjustable line weight headers and descriptions and if i can customize the colors of the sections as well, if i can have 2 blocks per row
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-content-section__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-content-section__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-content-section__preheader-{{ ai_gen_id }} {
    font-size: {{ block.settings.preheader_size }}px;
    color: {{ block.settings.preheader_color }};
    margin-bottom: 8px;
    font-weight: {{ block.settings.preheader_weight }};
    line-height: 1.4;
  }

  .ai-content-section__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: 1.2;
  }

  .ai-content-section__subheader-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheader_size }}px;
    color: {{ block.settings.subheader_color }};
    margin: 0;
    font-weight: {{ block.settings.subheader_weight }};
    line-height: 1.5;
  }

  .ai-content-section__blocks-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.block_spacing }}px;
    margin-top: {{ block.settings.content_spacing }}px;
  }

  .ai-content-block-{{ ai_gen_id }} {
    background-color: {{ block.settings.block_background_color }};
    padding: {{ block.settings.block_padding }}px;
    border-radius: {{ block.settings.block_border_radius }}px;
    border: {{ block.settings.block_border_width }}px solid {{ block.settings.block_border_color }};
    text-align: {{ block.settings.block_text_alignment }};
  }

  .ai-content-block__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.block_title_size }}px;
    color: {{ block.settings.block_title_color }};
    margin: 0 0 12px;
    font-weight: {{ block.settings.block_title_weight }};
    line-height: 1.3;
  }

  .ai-content-block__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.block_description_size }}px;
    color: {{ block.settings.block_description_color }};
    margin: 0;
    font-weight: {{ block.settings.block_description_weight }};
    line-height: 1.6;
  }

  @media screen and (max-width: 768px) {
    .ai-content-section__blocks-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.block_spacing | divided_by: 1.5 }}px;
    }

    .ai-content-section__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-content-section__preheader-{{ ai_gen_id }} {
      font-size: {{ block.settings.preheader_size | times: 0.9 }}px;
    }

    .ai-content-section__subheader-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheader_size | times: 0.9 }}px;
    }

    .ai-content-block__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.block_title_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-content-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-section__container-{{ ai_gen_id }}">
    {% if block.settings.preheader != blank or block.settings.heading != blank or block.settings.subheader != blank %}
      <div class="ai-content-section__header-{{ ai_gen_id }}">
        {% if block.settings.preheader != blank %}
          <div class="ai-content-section__preheader-{{ ai_gen_id }}">
            {{ block.settings.preheader }}
          </div>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h2 class="ai-content-section__heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.subheader != blank %}
          <div class="ai-content-section__subheader-{{ ai_gen_id }}">
            {{ block.settings.subheader }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-content-section__blocks-{{ ai_gen_id }}">
      {% if block.settings.block_1_title != blank or block.settings.block_1_description != blank %}
        <div class="ai-content-block-{{ ai_gen_id }}">
          {% if block.settings.block_1_title != blank %}
            <h3 class="ai-content-block__title-{{ ai_gen_id }}">
              {{ block.settings.block_1_title }}
            </h3>
          {% endif %}
          {% if block.settings.block_1_description != blank %}
            <div class="ai-content-block__description-{{ ai_gen_id }}">
              {{ block.settings.block_1_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.block_2_title != blank or block.settings.block_2_description != blank %}
        <div class="ai-content-block-{{ ai_gen_id }}">
          {% if block.settings.block_2_title != blank %}
            <h3 class="ai-content-block__title-{{ ai_gen_id }}">
              {{ block.settings.block_2_title }}
            </h3>
          {% endif %}
          {% if block.settings.block_2_description != blank %}
            <div class="ai-content-block__description-{{ ai_gen_id }}">
              {{ block.settings.block_2_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.block_3_title != blank or block.settings.block_3_description != blank %}
        <div class="ai-content-block-{{ ai_gen_id }}">
          {% if block.settings.block_3_title != blank %}
            <h3 class="ai-content-block__title-{{ ai_gen_id }}">
              {{ block.settings.block_3_title }}
            </h3>
          {% endif %}
          {% if block.settings.block_3_description != blank %}
            <div class="ai-content-block__description-{{ ai_gen_id }}">
              {{ block.settings.block_3_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.block_4_title != blank or block.settings.block_4_description != blank %}
        <div class="ai-content-block-{{ ai_gen_id }}">
          {% if block.settings.block_4_title != blank %}
            <h3 class="ai-content-block__title-{{ ai_gen_id }}">
              {{ block.settings.block_4_title }}
            </h3>
          {% endif %}
          {% if block.settings.block_4_description != blank %}
            <div class="ai-content-block__description-{{ ai_gen_id }}">
              {{ block.settings.block_4_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

