{% doc %}
  @prompt
    6 text with icons row with broader range of icons to choose from and it needs to be mobile friendly, can the icons be outlined instead of filled in with color, as well as a button on the bottom, can it be a horizontal row instead of vertical, i love it - can we just add headers with the text, can you add header + text for each icon/text, perfect! now i just want to adjust the weight of the icon outline
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-text-row-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-icon-text-row__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-icon-text-row__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: {{ block.settings.item_spacing }}px;
    margin-bottom: {{ block.settings.button_spacing }}px;
  }

  .ai-icon-text-row__item-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    display: flex;
    flex-direction: column;
    {% if block.settings.text_alignment == 'center' %}
      align-items: center;
    {% elsif block.settings.text_alignment == 'right' %}
      align-items: flex-end;
    {% else %}
      align-items: flex-start;
    {% endif %}
    gap: {{ block.settings.icon_text_spacing }}px;
  }

  .ai-icon-text-row__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
    stroke-width: {{ block.settings.icon_stroke_weight }};
    flex-shrink: 0;
  }

  .ai-icon-text-row__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.header_text_spacing }}px;
  }

  .ai-icon-text-row__header-{{ ai_gen_id }} {
    color: {{ block.settings.header_color }};
    font-size: {{ block.settings.header_size }}px;
    line-height: 1.2;
    margin: 0;
    font-family: var(--heading-font-family);
    font-weight: 600;
  }

  .ai-icon-text-row__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.4;
    margin: 0;
    font-family: var(--font-family);
  }

  .ai-icon-text-row__button-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-icon-text-row__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-family: var(--font-family);
    transition: all 0.3s ease;
    border: 2px solid {{ block.settings.button_border_color }};
  }

  .ai-icon-text-row__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 990px) {
    .ai-icon-text-row__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-icon-text-row__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.item_spacing | times: 0.75 }}px;
    }

    .ai-icon-text-row__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.85 }}px;
      height: {{ block.settings.icon_size | times: 0.85 }}px;
    }

    .ai-icon-text-row__header-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_size | times: 0.9 }}px;
    }

    .ai-icon-text-row__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-icon-text-row__container-{{ ai_gen_id }} {
      padding: 0 15px;
    }
  }
{% endstyle %}

<div class="ai-icon-text-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
