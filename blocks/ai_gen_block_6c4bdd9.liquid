                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
          {% endcase %}
          
          {% if header_value != blank or text_value != blank %}
            <div class="ai-icon-text-row__content-{{ ai_gen_id }}">
              {% if header_value != blank %}
                <h3 class="ai-icon-text-row__header-{{ ai_gen_id }}">{{ header_value }}</h3>
              {% endif %}
              {% if text_value != blank %}
                <p class="ai-icon-text-row__text-{{ ai_gen_id }}">{{ text_value }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    
    {% if block.settings.show_button and block.settings.button_text != blank %}
      <div class="ai-icon-text-row__button-wrapper-{{ ai_gen_id }}">
        <a href="{{ block.settings.button_link }}" class="ai-icon-text-row__button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

