      "default": "var(--font-heading-family)"
    },
    {
      "type": "range",
      "id": "header_bottom_spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Header bottom spacing",
      "default": 24
    },
    {
      "type": "header",
      "content": "Care instruction 1"
    },
    {
      "type": "text",
      "id": "gentle_wash_title",
      "label": "Title",
      "default": "Gentle wash"
    },
    {
      "type": "textarea",
      "id": "gentle_wash_description",
      "label": "Description",
      "default": "Machine wash cold with like colors on gentle cycle"
    },
    {
      "type": "image_picker",
      "id": "icon_1",
      "label": "Custom icon image"
    },
    {
      "type": "html",
      "id": "custom_svg_1",
      "label": "Custom SVG code"
    },
    {
      "type": "header",
      "content": "Care instruction 2"
    },
    {
      "type": "text",
      "id": "air_dry_title",
      "label": "Title",
      "default": "Air dry"
    },
    {
      "type": "textarea",
      "id": "air_dry_description",
      "label": "Description",
      "default": "Hang to dry or lay flat. Avoid direct sunlight"
    },
    {
      "type": "image_picker",
      "id": "icon_2",
      "label": "Custom icon image"
    },
    {
      "type": "html",
      "id": "custom_svg_2",
      "label": "Custom SVG code"
    },
    {
      "type": "header",
      "content": "Care instruction 3"
    },
    {
      "type": "text",
      "id": "iron_title",
      "label": "Title",
      "default": "Iron as needed"
    },
    {
      "type": "textarea",
      "id": "iron_description",
      "label": "Description",
      "default": "Iron on low heat if needed. Use pressing cloth for delicate fabrics"
    },
    {
      "type": "image_picker",
      "id": "icon_3",
      "label": "Custom icon image"
    },
    {
      "type": "html",
      "id": "custom_svg_3",
      "label": "Custom SVG code"
    },
    {
      "type": "header",
      "content": "Care instruction 4"
    },
    {
      "type": "text",
      "id": "no_bleach_title",
      "label": "Title",
      "default": "Avoid bleach"
    },
    {
      "type": "textarea",
      "id": "no_bleach_description",
      "label": "Description",
      "default": "Do not use bleach or harsh chemicals"
    },
    {
      "type": "image_picker",
      "id": "icon_4",
      "label": "Custom icon image"
    },
    {
      "type": "html",
      "id": "custom_svg_4",
      "label": "Custom SVG code"
    },
    {
      "type": "header",
      "content": "Layout"
