    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "range",
      "id": "image_max_width",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Image max width",
      "default": 600
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 10
    },
    {
      "type": "range",
      "id": "image_bottom_spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Image bottom spacing",
      "default": 32
    },
    {
      "type": "header",
      "content": "Main header"
    },
    {
      "type": "text",
      "id": "main_header",
      "label": "Header text",
      "default": "Care Instructions"
    },
    {
      "type": "range",
      "id": "header_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Header size",
      "default": 32
    },
    {
      "type": "color",
      "id": "header_color",
      "label": "Header color",
      "default": "#000000"
