    },
    {
      "type": "range",
      "id": "item_padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Item padding",
      "default": 20
    },
    {
      "type": "color",
      "id": "item_background_color",
      "label": "Item background color",
      "default": "#f8f8f8"
    },
    {
      "type": "range",
      "id": "item_border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Item border radius",
      "default": 8
    },
