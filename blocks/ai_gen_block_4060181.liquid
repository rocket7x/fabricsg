{% doc %}
  @prompt
    can you create me an image with a main header and then underneath have 4 icon and texts that include headers and descriptions. the icons should be related to: gentle wash, air dry, iron as needed, and avoid bleach, i would like to choose the icons
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-care-instructions-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-care-instructions-image-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.image_max_width }}px;
    margin: 0 auto {{ block.settings.image_bottom_spacing }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-care-instructions-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-care-instructions-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-care-instructions-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-care-instructions-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-care-instructions-header-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.header_bottom_spacing }}px;
    color: {{ block.settings.header_color }};
    font-size: {{ block.settings.header_size }}px;
    font-family: {{ block.settings.header_font }};
    line-height: 1.3;
  }

  .ai-care-instructions-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_top_spacing }}px;
  }

  .ai-care-instruction-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
  }

  .ai-care-instruction-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_bottom_spacing }}px;
    color: {{ block.settings.icon_color }};
    flex-shrink: 0;
  }

  .ai-care-instruction-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-care-instruction-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-care-instruction-title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_bottom_spacing }}px;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-care-instruction-description-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-care-instructions-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-care-instructions-header-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.header_size }}px * 0.8);
    }

    .ai-care-instruction-icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.8);
      height: calc({{ block.settings.icon_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="ai-care-instructions-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.image %}
    <div class="ai-care-instructions-image-{{ ai_gen_id }}">
      <img
        src="{{ block.settings.image | image_url: width: 1000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
      >
    </div>
  {% else %}
    <div class="ai-care-instructions-image-{{ ai_gen_id }}">
      <div class="ai-care-instructions-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-care-instructions-empty-state-{{ ai_gen_id }}">
          Add an image to showcase your product
        </div>
      </div>
    </div>
  {% endif %}

  {% if block.settings.main_header != blank %}
    <h2 class="ai-care-instructions-header-{{ ai_gen_id }}">{{ block.settings.main_header }}</h2>
  {% endif %}

  <div class="ai-care-instructions-grid-{{ ai_gen_id }}">
    <div class="ai-care-instruction-item-{{ ai_gen_id }}">
      <div class="ai-care-instruction-icon-{{ ai_gen_id }}">
        {% if block.settings.icon_1 %}
          <img
            src="{{ block.settings.icon_1 | image_url: width: 100 }}"
            alt="{{ block.settings.gentle_wash_title | escape }}"
            loading="lazy"
          >
        {% else %}
          {% if block.settings.custom_svg_1 != blank %}
            {{ block.settings.custom_svg_1 }}
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 6h18l-2 13H5L3 6z"/>
              <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
              <circle cx="9" cy="12" r="1"/>
              <circle cx="15" cy="12" r="1"/>
              <path d="M7 16c0-1.1.9-2 2-2h6c1.1 0 2 .9 2 2"/>
            </svg>
          {% endif %}
        {% endif %}
      </div>
      <h3 class="ai-care-instruction-title-{{ ai_gen_id }}">{{ block.settings.gentle_wash_title }}</h3>
      <p class="ai-care-instruction-description-{{ ai_gen_id }}">{{ block.settings.gentle_wash_description }}</p>
    </div>

    <div class="ai-care-instruction-item-{{ ai_gen_id }}">
      <div class="ai-care-instruction-icon-{{ ai_gen_id }}">
        {% if block.settings.icon_2 %}
          <img
            src="{{ block.settings.icon_2 | image_url: width: 100 }}"
            alt="{{ block.settings.air_dry_title | escape }}"
            loading="lazy"
          >
        {% else %}
          {% if block.settings.custom_svg_2 != blank %}
            {{ block.settings.custom_svg_2 }}
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 2v4"/>
              <path d="M16 2v4"/>
              <path d="M21 6H3"/>
              <path d="M3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6"/>
              <path d="M8 10h8"/>
              <path d="M8 14h8"/>
            </svg>
          {% endif %}
        {% endif %}
      </div>
      <h3 class="ai-care-instruction-title-{{ ai_gen_id }}">{{ block.settings.air_dry_title }}</h3>
      <p class="ai-care-instruction-description-{{ ai_gen_id }}">{{ block.settings.air_dry_description }}</p>
    </div>

    <div class="ai-care-instruction-item-{{ ai_gen_id }}">
      <div class="ai-care-instruction-icon-{{ ai_gen_id }}">
        {% if block.settings.icon_3 %}
          <img
            src="{{ block.settings.icon_3 | image_url: width: 100 }}"
            alt="{{ block.settings.iron_title | escape }}"
            loading="lazy"
          >
        {% else %}
          {% if block.settings.custom_svg_3 != blank %}
            {{ block.settings.custom_svg_3 }}
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v20"/>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              <path d="M9 9h8"/>
              <path d="M7 15h8"/>
            </svg>
          {% endif %}
        {% endif %}
      </div>
      <h3 class="ai-care-instruction-title-{{ ai_gen_id }}">{{ block.settings.iron_title }}</h3>
      <p class="ai-care-instruction-description-{{ ai_gen_id }}">{{ block.settings.iron_description }}</p>
    </div>

    <div class="ai-care-instruction-item-{{ ai_gen_id }}">
      <div class="ai-care-instruction-icon-{{ ai_gen_id }}">
        {% if block.settings.icon_4 %}
          <img
            src="{{ block.settings.icon_4 | image_url: width: 100 }}"
            alt="{{ block.settings.no_bleach_title | escape }}"
            loading="lazy"
          >
        {% else %}
          {% if block.settings.custom_svg_4 != blank %}
            {{ block.settings.custom_svg_4 }}
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="15" y1="9" x2="9" y2="15"/>
              <line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
          {% endif %}
        {% endif %}
      </div>
      <h3 class="ai-care-instruction-title-{{ ai_gen_id }}">{{ block.settings.no_bleach_title }}</h3>
      <p class="ai-care-instruction-description-{{ ai_gen_id }}">{{ block.settings.no_bleach_description }}</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Care instructions",
  "settings": [
    {
      "type": "header",
      "content": "Image"
