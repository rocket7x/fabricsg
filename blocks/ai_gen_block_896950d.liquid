{% doc %}
  @prompt
    can i have 6 multicolumn icon and texts for: versatile, heart, stitching, essential, leaf, and gift, can i adjust the line weight of the icon, can you change the perfect gift icon to a gift box, can you change the perfect gift icon to a bow, can it be 3 columns per row on desktop, can the perfect gift icon be a gift box
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multicolumn-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-multicolumn-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-multicolumn-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.column_gap }}px;
    align-items: start;
  }

  .ai-multicolumn-item-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-multicolumn-item-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
  }

  .ai-multicolumn-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_margin_bottom }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background_color }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-multicolumn-icon-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size | times: 0.6 }}px;
    height: {{ block.settings.icon_size | times: 0.6 }}px;
    stroke-width: {{ block.settings.icon_stroke_width }};
  }

  .ai-multicolumn-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    line-height: 1.3;
  }

  .ai-multicolumn-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_font_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .ai-multicolumn-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.column_gap | times: 0.75 }}px;
    }

    .ai-multicolumn-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-multicolumn-icon-{{ ai_gen_id }} svg {
      width: {{ block.settings.icon_size | times: 0.5 }}px;
      height: {{ block.settings.icon_size | times: 0.5 }}px;
    }

    .ai-multicolumn-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.9 }}px;
    }

    .ai-multicolumn-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-multicolumn-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-multicolumn-container-{{ ai_gen_id }}">
    <div class="ai-multicolumn-grid-{{ ai_gen_id }}">
      
      <div class="ai-multicolumn-item-{{ ai_gen_id }}">
        <div class="ai-multicolumn-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="m2 17 10 5 10-5"/>
            <path d="m2 12 10 5 10-5"/>
          </svg>
        </div>
        <h3 class="ai-multicolumn-title-{{ ai_gen_id }}">{{ block.settings.versatile_title }}</h3>
        <p class="ai-multicolumn-text-{{ ai_gen_id }}">{{ block.settings.versatile_text }}</p>
      </div>

      <div class="ai-multicolumn-item-{{ ai_gen_id }}">
        <div class="ai-multicolumn-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </div>
        <h3 class="ai-multicolumn-title-{{ ai_gen_id }}">{{ block.settings.heart_title }}</h3>
        <p class="ai-multicolumn-text-{{ ai_gen_id }}">{{ block.settings.heart_text }}</p>
      </div>

      <div class="ai-multicolumn-item-{{ ai_gen_id }}">
        <div class="ai-multicolumn-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20h9"/>
            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
          </svg>
        </div>
        <h3 class="ai-multicolumn-title-{{ ai_gen_id }}">{{ block.settings.stitching_title }}</h3>
        <p class="ai-multicolumn-text-{{ ai_gen_id }}">{{ block.settings.stitching_text }}</p>
      </div>

      <div class="ai-multicolumn-item-{{ ai_gen_id }}">
        <div class="ai-multicolumn-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
          </svg>
        </div>
        <h3 class="ai-multicolumn-title-{{ ai_gen_id }}">{{ block.settings.essential_title }}</h3>
        <p class="ai-multicolumn-text-{{ ai_gen_id }}">{{ block.settings.essential_text }}</p>
      </div>

      <div class="ai-multicolumn-item-{{ ai_gen_id }}">
        <div class="ai-multicolumn-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
            <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
          </svg>
        </div>
        <h3 class="ai-multicolumn-title-{{ ai_gen_id }}">{{ block.settings.leaf_title }}</h3>
        <p class="ai-multicolumn-text-{{ ai_gen_id }}">{{ block.settings.leaf_text }}</p>
      </div>

      <div class="ai-multicolumn-item-{{ ai_gen_id }}">
        <div class="ai-multicolumn-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="8" width="18" height="4" rx="1"/>
            <path d="m12 8-2-4h4l-2 4"/>
            <path d="M8 12v9l4-2 4 2v-9"/>
          </svg>
        </div>
        <h3 class="ai-multicolumn-title-{{ ai_gen_id }}">{{ block.settings.gift_title }}</h3>
        <p class="ai-multicolumn-text-{{ ai_gen_id }}">{{ block.settings.gift_text }}</p>
      </div>

    </div>
  </div>
</div>

