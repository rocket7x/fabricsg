{% doc %}
  @prompt
    a horizontal icon and text section that contains: 100% cotton, 30 day returns, secure payments, and eco-friendly, can i adjust the line weight of the text as well as change the icons for "100% cotton" and "eco-friendly", for the "100% cotton" can the icon be a cotton plant/ball, for mobile can i choose whether its stacked or not, on mobile can they be all on one line instead of stacked
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-text-section-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.spacing_between_items }}px;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    flex-wrap: wrap;
  }

  .ai-icon-text-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
    flex-direction: {{ block.settings.layout_direction }};
    text-align: center;
  }

  .ai-icon-text-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-icon-text-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke-width: {{ block.settings.icon_stroke_width }};
  }

  .ai-icon-text-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: {{ block.settings.text_weight }};
    line-height: {{ block.settings.text_line_height }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-text-section-{{ ai_gen_id }} {
      gap: {{ block.settings.spacing_between_items | times: 0.7 }}px;
      {% if block.settings.mobile_layout == 'stacked' %}
        flex-direction: column;
      {% elsif block.settings.mobile_layout == 'single_line' %}
        flex-wrap: nowrap;
        overflow-x: auto;
        justify-content: flex-start;
        padding-left: 10px;
        padding-right: 10px;
      {% endif %}
    }

    .ai-icon-text-item-{{ ai_gen_id }} {
      gap: {{ block.settings.icon_text_gap | times: 0.8 }}px;
      {% if block.settings.mobile_layout == 'stacked' %}
        width: 100%;
        justify-content: center;
      {% elsif block.settings.mobile_layout == 'single_line' %}
        flex-shrink: 0;
      {% endif %}
    }

    .ai-icon-text-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-icon-text-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
      {% if block.settings.mobile_layout == 'single_line' %}
        white-space: nowrap;
      {% endif %}
    }
  }
{% endstyle %}

<div class="ai-icon-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-text-item-{{ ai_gen_id }}">
    <div class="ai-icon-text-icon-{{ ai_gen_id }}">
      {% if block.settings.icon_1_style == 'cotton_ball' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="7" r="3"/>
          <circle cx="15" cy="7" r="3"/>
          <circle cx="9" cy="13" r="3"/>
          <circle cx="15" cy="13" r="3"/>
          <path d="M12 16v6"/>
          <path d="M10 22h4"/>
        </svg>
      {% elsif block.settings.icon_1_style == 'cotton_plant' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22v-8"/>
          <circle cx="10" cy="6" r="2.5"/>
          <circle cx="14" cy="6" r="2.5"/>
          <circle cx="10" cy="11" r="2.5"/>
          <circle cx="14" cy="11" r="2.5"/>
          <path d="M12 14c-1.5 0-2.5-1-2.5-2.5"/>
          <path d="M12 14c1.5 0 2.5-1 2.5-2.5"/>
        </svg>
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <line x1="3" y1="9" x2="21" y2="9"/>
          <line x1="3" y1="15" x2="21" y2="15"/>
          <line x1="9" y1="3" x2="9" y2="21"/>
          <line x1="15" y1="3" x2="15" y2="21"/>
        </svg>
      {% endif %}
    </div>
    <p class="ai-icon-text-text-{{ ai_gen_id }}">{{ block.settings.item_1_text }}</p>
  </div>

  <div class="ai-icon-text-item-{{ ai_gen_id }}">
    <div class="ai-icon-text-icon-{{ ai_gen_id }}">
      {% if block.settings.icon_2_style == 'return' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 14 4 9 9 4"/>
          <path d="M20 20v-7a4 4 0 0 0-4-4H4"/>
        </svg>
      {% elsif block.settings.icon_2_style == 'calendar' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
          <path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01M16 18h.01"/>
        </svg>
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
          <path d="M9 6h6"/>
        </svg>
      {% endif %}
    </div>
    <p class="ai-icon-text-text-{{ ai_gen_id }}">{{ block.settings.item_2_text }}</p>
  </div>

  <div class="ai-icon-text-item-{{ ai_gen_id }}">
    <div class="ai-icon-text-icon-{{ ai_gen_id }}">
      {% if block.settings.icon_3_style == 'lock' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      {% elsif block.settings.icon_3_style == 'shield' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
          <line x1="1" y1="10" x2="23" y2="10"/>
        </svg>
      {% endif %}
    </div>
    <p class="ai-icon-text-text-{{ ai_gen_id }}">{{ block.settings.item_3_text }}</p>
  </div>

  <div class="ai-icon-text-item-{{ ai_gen_id }}">
    <div class="ai-icon-text-icon-{{ ai_gen_id }}">
      {% if block.settings.icon_4_style == 'leaf' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
          <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
        </svg>
      {% elsif block.settings.icon_4_style == 'recycle' %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 19H4.815a1.83 1.83 0 0 1-1.57-.881 1.785 1.785 0 0 1-.004-1.784L7.196 9.5"/>
          <path d="M11 19h8.203a1.83 1.83 0 0 0 1.556-.89 1.784 1.784 0 0 0 0-1.775l-1.226-2.12"/>
          <path d="m14 16-3 3 3 3"/>
          <path d="M8.293 13.596 7.196 9.5 3.1 10.598"/>
          <path d="m9.344 5.811 1.093-1.892A1.83 1.83 0 0 1 11.985 3a1.784 1.784 0 0 1 1.546.888l3.943 6.843"/>
          <path d="m13.378 9.633 4.096 1.098 1.097-4.096"/>
        </svg>
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      {% endif %}
    </div>
    <p class="ai-icon-text-text-{{ ai_gen_id }}">{{ block.settings.item_4_text }}</p>
  </div>
</div>

{% schema %}
{
  "name": "Icon and text section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "item_1_text",
      "label": "Item 1 text",
      "default": "100% Cotton"
    },
    {
      "type": "select",
      "id": "icon_1_style",
      "label": "Item 1 icon",
      "options": [
        {
          "value": "cotton_ball",
          "label": "Cotton ball"
        },
        {
          "value": "cotton_plant",
          "label": "Cotton plant"
        },
        {
          "value": "fabric",
          "label": "Fabric"
        }
      ],
      "default": "cotton_ball"
    },
    {
      "type": "text",
      "id": "item_2_text",
      "label": "Item 2 text",
      "default": "30 Day Returns"
    },
    {
      "type": "select",
      "id": "icon_2_style",
      "label": "Item 2 icon",
      "options": [
        {
          "value": "return",
          "label": "Return arrow"
        },
        {
          "value": "calendar",
          "label": "Calendar"
        },
        {
          "value": "home",
          "label": "Home"
        }
      ],
      "default": "return"
    },
    {
      "type": "text",
      "id": "item_3_text",
      "label": "Item 3 text",
      "default": "Secure Payments"
    },
    {
      "type": "select",
      "id": "icon_3_style",
      "label": "Item 3 icon",
      "options": [
        {
          "value": "lock",
          "label": "Lock"
        },
        {
          "value": "shield",
          "label": "Shield"
        },
        {
          "value": "card",
          "label": "Credit card"
        }
      ],
      "default": "lock"
    },
    {
      "type": "text",
      "id": "item_4_text",
      "label": "Item 4 text",
      "default": "Eco-Friendly"
    },
    {
      "type": "select",
      "id": "icon_4_style",
      "label": "Item 4 icon",
      "options": [
        {
          "value": "leaf",
          "label": "Leaf"
        },
        {
          "value": "recycle",
          "label": "Recycle"
        },
        {
          "value": "droplet",
          "label": "Droplet"
        }
      ],
      "default": "leaf"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_direction",
      "label": "Icon position",
      "options": [
        {
          "value": "row",
          "label": "Left of text"
        },
        {
          "value": "column",
          "label": "Above text"
        }
      ],
      "default": "row"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "wrapped",
          "label": "Wrapped"
        },
        {
          "value": "single_line",
          "label": "Single line"
        },
        {
          "value": "stacked",
          "label": "Stacked"
        }
      ],
      "default": "single_line"
    },
    {
      "type": "range",
      "id": "spacing_between_items",
      "label": "Spacing between items",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Icon to text gap",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "icon_stroke_width",
      "label": "Icon line weight",
      "min": 1,
      "max": 3,
      "step": 0.5,
      "default": 2
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "text_line_height",
      "label": "Text line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.4
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Icon and text section"
    }
  ]
}
{% endschema %}
