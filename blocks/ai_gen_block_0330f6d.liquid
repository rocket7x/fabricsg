{% doc %}
  @prompt
    image on the left with a buy more save more deal section for Flat 10% OFF on order above $100, i love it, can i adjust the line weight of the header text and button text. as well as move the alignment on mobile to the left, can i get a "special offer" subheading too
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-deal-section-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 40px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    max-width: 100%;
  }

  .ai-deal-image-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.image_width }}px;
    max-width: 50%;
  }

  .ai-deal-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-deal-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-deal-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-deal-image-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.5;
  }

  .ai-deal-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-deal-subheading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.subheading_font_size }}px;
    font-weight: {{ block.settings.subheading_font_weight }};
    color: {{ block.settings.subheading_color }};
    line-height: 1.3;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-deal-header-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.header_font_size }}px;
    font-weight: {{ block.settings.header_font_weight }};
    color: {{ block.settings.header_color }};
    line-height: 1.2;
  }

  .ai-deal-description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
  }

  .ai-deal-offer-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px 20px;
    background-color: {{ block.settings.offer_background_color }};
    border-radius: {{ block.settings.offer_border_radius }}px;
    border: 2px solid {{ block.settings.offer_border_color }};
  }

  .ai-deal-percentage-{{ ai_gen_id }} {
    font-size: {{ block.settings.percentage_font_size }}px;
    font-weight: {{ block.settings.percentage_font_weight }};
    color: {{ block.settings.percentage_color }};
    margin: 0;
  }

  .ai-deal-offer-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.offer_text_font_size }}px;
    color: {{ block.settings.offer_text_color }};
    margin: 0;
  }

  .ai-deal-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 30px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    border: 2px solid {{ block.settings.button_border_color }};
    transition: all 0.3s ease;
    align-self: flex-start;
  }

  .ai-deal-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-deal-section-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 30px;
      padding: 30px 20px;
      {% if block.settings.mobile_alignment == 'left' %}
        text-align: left;
      {% elsif block.settings.mobile_alignment == 'center' %}
        text-align: center;
      {% else %}
        text-align: right;
      {% endif %}
    }

    .ai-deal-image-{{ ai_gen_id }} {
      width: 100%;
      max-width: 100%;
    }

    .ai-deal-content-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-deal-offer-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 10px;
      text-align: center;
    }

    .ai-deal-button-{{ ai_gen_id }} {
      {% if block.settings.mobile_alignment == 'left' %}
        align-self: flex-start;
      {% elsif block.settings.mobile_alignment == 'center' %}
        align-self: center;
      {% else %}
        align-self: flex-end;
      {% endif %}
    }
  }
{% endstyle %}

<div class="ai-deal-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-deal-image-{{ ai_gen_id }}">
    <div class="ai-deal-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 600 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="ai-deal-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
  </div>

  <div class="ai-deal-content-{{ ai_gen_id }}">
    {% if block.settings.subheading_text != blank %}
      <p class="ai-deal-subheading-{{ ai_gen_id }}">{{ block.settings.subheading_text }}</p>
    {% endif %}

    {% if block.settings.header_text != blank %}
      <h2 class="ai-deal-header-{{ ai_gen_id }}">{{ block.settings.header_text }}</h2>
    {% endif %}

    {% if block.settings.description_text != blank %}
      <p class="ai-deal-description-{{ ai_gen_id }}">{{ block.settings.description_text }}</p>
    {% endif %}

    <div class="ai-deal-offer-{{ ai_gen_id }}">
      {% if block.settings.percentage_text != blank %}
        <h3 class="ai-deal-percentage-{{ ai_gen_id }}">{{ block.settings.percentage_text }}</h3>
      {% endif %}
      {% if block.settings.offer_text != blank %}
        <p class="ai-deal-offer-text-{{ ai_gen_id }}">{{ block.settings.offer_text }}</p>
      {% endif %}
    </div>

    {% if block.settings.button_text != blank and block.settings.button_link != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-deal-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

