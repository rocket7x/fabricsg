{% doc %}
  @prompt
    can you create a section with a header and description on the left with an image on the right. for the header and description the line weight needs to be adjustable and the image needs to be able to customize different sizes
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-image-section-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.content_gap }}px;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-content-image-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    width: 100%;
    display: flex;
    align-items: center;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-content-wrapper-{{ ai_gen_id }} {
    flex: 1;
    max-width: 50%;
  }

  .ai-content-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    font-weight: {{ block.settings.heading_font_weight }};
    margin: 0 0 {{ block.settings.content_spacing }}px;
  }

  .ai-content-description-{{ ai_gen_id }} {
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    line-height: {{ block.settings.description_line_height }};
    font-weight: {{ block.settings.description_font_weight }};
    margin: 0;
  }

  .ai-image-wrapper-{{ ai_gen_id }} {
    flex: 1;
    max-width: 50%;
  }

  .ai-image-container-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 768px) {
    .ai-content-image-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.mobile_content_gap }}px;
    }

    .ai-content-wrapper-{{ ai_gen_id }},
    .ai-image-wrapper-{{ ai_gen_id }} {
      max-width: 100%;
    }

    {% if block.settings.mobile_image_first %}
      .ai-image-wrapper-{{ ai_gen_id }} {
        order: -1;
      }
    {% endif %}

    .ai-content-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-content-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_description_size }}px;
    }

    .ai-image-container-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_image_height }}px;
    }
  }
{% endstyle %}

<div class="ai-content-image-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-image-container-{{ ai_gen_id }}">
    <div class="ai-content-wrapper-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-content-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      
      {% if block.settings.description != blank %}
        <div class="ai-content-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}
    </div>

    <div class="ai-image-wrapper-{{ ai_gen_id }}">
      <div class="ai-image-container-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="ai-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {% else %}
          <div class="ai-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-empty-state-{{ ai_gen_id }}">
              Add an image
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Content with image",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Your heading here</p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Add your description text here. This content will appear on the left side of the section.</p>"
    },
    {
      "type": "range",
      "id": "content_spacing",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Space between heading and description",
      "default": 16
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Heading line height",
      "default": 1.2
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Description style"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    },
    {
      "type": "range",
      "id": "description_line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Description line height",
      "default": 1.6
    },
    {
      "type": "select",
      "id": "description_font_weight",
      "label": "Description font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_height",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Image height",
      "default": 400
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Gap between content and image",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "header",
      "content": "Mobile settings"
    },
    {
      "type": "checkbox",
      "id": "mobile_image_first",
      "label": "Show image first on mobile",
      "default": false
    },
    {
      "type": "range",
      "id": "mobile_content_gap",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Mobile gap between content and image",
      "default": 30
    },
    {
      "type": "range",
      "id": "mobile_heading_size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Mobile heading size",
      "default": 24
    },
    {
      "type": "range",
      "id": "mobile_description_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Mobile description size",
      "default": 14
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "min": 150,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Mobile image height",
      "default": 250
    }
  ],
  "presets": [
    {
      "name": "Content with image"
    }
  ]
}
{% endschema %}