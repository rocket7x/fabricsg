{% doc %}
  @prompt
    image on the left with a buy more save more deal section for Flat 10% OFF on order above $100, i love it, can i adjust the line weight of the header text and button text. as well as move the alignment on mobile to the left
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-deal-section-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.content_gap }}px;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    max-width: 100%;
  }

  .ai-deal-image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    position: relative;
  }

  .ai-deal-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-deal-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 300px;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-deal-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.5;
  }

  .ai-deal-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-deal-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-deal-badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_background_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 16px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    align-self: flex-start;
  }

  .ai-deal-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    line-height: 1.2;
    margin: 0;
  }

  .ai-deal-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_font_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .ai-deal-offer-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: {{ block.settings.offer_padding }}px;
    background-color: {{ block.settings.offer_background_color }};
    border: 2px solid {{ block.settings.offer_border_color }};
    border-radius: {{ block.settings.offer_border_radius }}px;
  }

  .ai-deal-discount-{{ ai_gen_id }} {
    font-size: {{ block.settings.discount_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.discount_color }};
  }

  .ai-deal-threshold-{{ ai_gen_id }} {
    font-size: {{ block.settings.threshold_font_size }}px;
    color: {{ block.settings.threshold_color }};
  }

  .ai-deal-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: 2px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    transition: all 0.3s ease;
    align-self: flex-start;
  }

  .ai-deal-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 768px) {
    .ai-deal-section-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: left;
    }

    .ai-deal-image-wrapper-{{ ai_gen_id }} {
      flex: none;
      width: 100%;
      max-width: 300px;
    }

    .ai-deal-content-{{ ai_gen_id }} {
      align-items: flex-start;
    }

    .ai-deal-badge-{{ ai_gen_id }},
    .ai-deal-button-{{ ai_gen_id }} {
      align-self: flex-start;
    }

    .ai-deal-offer-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: left;
      gap: 8px;
      align-items: flex-start;
    }
  }
{% endstyle %}

<div
  class="ai-deal-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-deal-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 600 }}"
        alt="{{ block.settings.image.alt | escape }}"
        class="ai-deal-image-{{ ai_gen_id }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
      >
    {% else %}
      <div class="ai-deal-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-deal-empty-state-{{ ai_gen_id }}">
          Add an image to showcase your deal
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-deal-content-{{ ai_gen_id }}">
    {% if block.settings.badge_text != blank %}
      <span class="ai-deal-badge-{{ ai_gen_id }}">{{ block.settings.badge_text }}</span>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-deal-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-deal-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}

    <div class="ai-deal-offer-{{ ai_gen_id }}">
      <span class="ai-deal-discount-{{ ai_gen_id }}">{{ block.settings.discount_text }}</span>
      <span class="ai-deal-threshold-{{ ai_gen_id }}">{{ block.settings.threshold_text }}</span>
    </div>

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-deal-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

