    "faq_section_K47nej": {
      "type": "faq-section",
      "blocks": {
        "faq_VBEwND": {
          "type": "faq",
          "settings": {
            "heading": "What size table runner do I need?",
            "answer": "<p>The ideal size depends on your table length and style preference. Generally, a table runner should hang 6-12 inches over each end of the table. For a modern look, you can also use shorter runners that sit just in the center.</p>"
          }
        },
        "faq_fanCM4": {
          "type": "faq",
          "settings": {
            "heading": "Are your table runners machine washable?",
            "answer": "<p>Yes! Our cotton and linen table runners are machine washable and easy to maintain. We recommend gentle washing in cold water and air drying to keep the colors vibrant.</p>"
          }
        },
        "faq_aTqTaw": {
          "type": "faq",
          "settings": {
            "heading": "Can I use a table runner with a tablecloth?",
            "answer": "<p>Absolutely! Layering a runner over a tablecloth creates a beautiful, layered look - perfect for weddings, festive gatherings, and formal dining setups.</p>"
          }
        },
        "faq_HRgNqD": {
          "type": "faq",
          "settings": {
            "heading": "Do table runners work for round tables?",
            "answer": "<p>Yes, table runners are versatile. You can place one across the center or crisscross two runners for a stylish arrangement on round tables.</p>"
          }
        },
        "faq_mqDt7t": {
          "type": "faq",
          "settings": {
            "heading": "What decor styles do these table runners complement?",
            "answer": "<p>Our handmade block print and cotton runners suit farmhouse, boho, rustic, vintage, and even modern minimalist decor, making them perfect for both everyday dining and special occasions.</p>"
          }
        }
      },
