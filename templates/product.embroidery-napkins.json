      "blocks": {
        "faq_T7cQbj": {
          "type": "faq",
          "settings": {
            "heading": "What materials are used in your embroidery napkins?",
            "answer": "<p>Our embroidery napkins are made from high-quality, soft, and durable cotton, ensuring comfort, long-lasting use, and easy care.</p>"
          }
        },
        "faq_BRGPNP": {
          "type": "faq",
          "settings": {
            "heading": "Are these napkins machine washable?",
            "answer": "<p>Yes! These napkins are designed for everyday use and are machine washable, retaining their intricate embroidery and vibrant colors even after multiple washes.</p>"
          }
        },
        "faq_GDTcew": {
          "type": "faq",
          "settings": {
            "heading": "Can embroidery napkins be used for special occasions?",
            "answer": "<p>Absolutely. Their elegant designs make them perfect for weddings, festive dinners, parties, or even casual dining.</p>"
          }
        },
        "faq_7VemEa": {
          "type": "faq",
          "settings": {
            "heading": "Do you offer different designs or colors?",
            "answer": "<p>Yes, we offer a wide variety of embroidered patterns and colors to match any table setting or decor style.</p>"
          }
        },
        "faq_yVdehh": {
          "type": "faq",
          "settings": {
            "heading": "How should I store embroidery napkins?",
            "answer": "<p>Store them folded in a cool, dry place. For long-term care, keep them away from direct sunlight to preserve the embroidery and colors.</p>"
          }
        }
