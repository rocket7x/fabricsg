    "faq_section_qX8BjU": {
      "type": "faq-section",
      "blocks": {
        "faq_ynMeRU": {
          "type": "faq",
          "settings": {
            "heading": "How do I care for my block print cotton curtains?",
            "answer": "<p>These curtains are easy to maintain. We recommend gentle machine wash or hand wash in cold water with mild detergent. Avoid bleach and direct harsh sunlight to preserve the natural colors of the cotton drapes.</p>"
          }
        },
        "faq_bLAa9N": {
          "type": "faq",
          "settings": {
            "heading": "Are these cotton drapes sheer or opaque?",
            "answer": "<p>We offer both styles. Our Sheer Cotton Curtains gently filter light while maintaining privacy, whereas thicker block print cotton curtains provide more coverage and insulation.</p>"
          }
        },
        "faq_49pVdY": {
          "type": "faq",
          "settings": {
            "heading": "Do sheer cotton curtains provide privacy?",
            "answer": "<p>Yes, sheer cotton curtains allow natural light to flow in while softly diffusing it, offering semi-privacy. For complete privacy, you can layer them with solid cotton drapes.</p>"
          }
        },
        "faq_qQFrpW": {
          "type": "faq",
          "settings": {
            "heading": "Can these curtains be used for different rooms?",
            "answer": "<p>Absolutely! Whether you’re decorating your living room, bedroom, dining area, or office, our cotton drapes bring a fresh, natural, and elegant vibe to any space.</p>"
          }
        },
        "faq_LN3kiN": {
          "type": "faq",
          "settings": {
            "heading": "Are these eco-friendly?",
            "answer": "<p>Yes. Made from 100% natural cotton and printed with traditional, sustainable techniques, our block print cotton curtains are an eco-conscious choice for modern homes.</p>"
          }
        }
      },
