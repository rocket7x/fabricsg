{{ 'categories.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign blocks_count = section.blocks.size
  if blocks_count >= 3 and blocks_count <= 5
    assign class_name = 'slider-with-3-items'
    assign slide_count = 3
  elsif blocks_count > 5 and blocks_count <= 7
    assign class_name = 'slider-with-5-items'
    assign slide_count = 5
  elsif blocks_count > 7 
    assign class_name = 'slider-with-7-items'
    assign slide_count = 7
  else
    assign class_name = 'slider-normal'
    assign slide_count = 3
  endif

  if blocks_count >= 3
    assign enable_slider = true
  else
    assign enable_slider = false
  endif
-%}


<div class="container sm-container" data-section-type="categories" data-blocks-count="{{ blocks_count }}">
  {% if section.settings.heading != blank or section.settings.subheading != blank %}
    <div class="section-header text-center">
      {% if section.settings.subheading != blank %}
        <p class="heading-subtitle text-center">{{ section.settings.subheading }}</p>
      {% endif %}
      {% if section.settings.highlight_font == 'body' %}
        {% capture highlightStyle %}
        <span class="body-font highlighted-text">
        {% endcapture %}
      {% elsif section.settings.highlight_font == 'heading' %}
      {% capture highlightStyle %}
         <span class="heading-font highlighted-text">
      {% endcapture %}  
      {% else %}
      {% capture highlightStyle %}
         <span class="accent-font highlighted-text">
      {% endcapture %}  
      {% endif %}
      <{{ section.settings.seo_heading }} class="heading-title text-center {{ section.settings.heading_size }}">
        {%- assign heading = section.settings.heading | replace: "<strong>", highlightStyle | replace: "</strong>", '</span>' | replace: '++', '<br/>' -%}
        {%- if heading contains '[' and heading contains ']' -%}
          {%- render 'rotational-highlight', heading: heading -%}
        {%- else -%}
          {{- heading -}}
        {%- endif -%}
      </{{ section.settings.seo_heading }}>
    </div>
    {% endif %}
  <div class="yv-catgeories-main-wrapper">
    <div
      class="yv-catgeories-wrapper {{ class_name }}"
      id="yv-catgeories-{{ section.id }}"
      {% if enable_slider %}
      data-flickity-slider='
        {
          "wrapAround":true,
          "cellAlign": "center",
          "dragThreshold": 10,
          "touchVerticalScroll": false,
          "contain": true,
          "resize": true,
          "prevNextButtons": true,
          "pageDots": false,
          "arrowShape":"M50.1228 1.62718C48.1063 -0.542395 44.8369 -0.542395 42.8204 1.62718L1.51235 46.0716C-0.504121 48.2412 -0.504121 51.7588 1.51235 53.9284L42.8204 98.3728C44.8369 100.542 48.1063 100.542 50.1228 98.3728C52.1392 96.2032 52.1392 92.6857 50.1228 90.5161L17.6293 55.5556H94.8365C97.6882 55.5556 100 53.0682 100 50C100 46.9317 97.6882 44.4444 94.8365 44.4444H17.6293L50.1228 9.48393C52.1392 7.31435 52.1392 3.79676 50.1228 1.62718Z"
        }'
      {% endif %}
    >
      {%- for block in section.blocks -%}
        {%- liquid
          if block.settings.collection.url != blank
            assign tag = 'a'
          else
            assign tag = 'div'
          endif
        -%}
      <div class="yv-categories-card">
        <{{ tag }} {% if tag == 'a' %} href="{{ block.settings.collection.url }}" {% endif %} class="yv-categories-media">
          <div class="yv-categories-image">
            <div class="image-wrapper image-square">
              {%- liquid
                assign category_image = block.settings.category_image | default: block.settings.collection.featured_image 
                assign alt = block.settings.category_title | default: block.settings.collection.title
              -%}
              {%- if category_image != blank -%}
              {{- 
                category_image 
                | image_url: width: 1200, format: 'webp'
                | image_tag:
                widths: '300,400,500,600,700,800,900,1000',
                sizes: '(max-width: 767px) 50vw, 25vw', 
                loading: 'lazy',
                fetchpriority: 'auto',
                alt: alt
              -}}
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
          </div>
          <div class="yv-border-holder">
            <div class="yv-category-border"></div>
            <div class="yv-category-border yv-category-border-secondary"></div>
            <div class="yv-category-border yv-category-border-tertiary"></div>
          </div>
        </{{ tag }}>
        {% comment %} <div class="yv-categories-content">
          <{{ tag }} {% if tag == 'a' %} href="{{ block.settings.collection.url }}" {% endif %} class="d-block yv-categories-title text-center h6">{{ block.settings.category_title | default: block.settings.collection.title }}</{{ tag }}>
        </div> {% endcomment %}
      </div>
      {%- endfor -%}
    </div>

    <div  class="yv-catgeories-content-wrapper {{ class_name }}"
      {% if enable_slider %}
        data-flickity-slider='
          {
            "asNavFor":"#yv-catgeories-{{ section.id }}",
            "fade": true,
            "wrapAround":true,
            "cellAlign": "center",
            "dragThreshold": 10,
            "touchVerticalScroll": false,
            "contain": true,
            "resize": true,
            "prevNextButtons": false,
            "pageDots": false
          }'
        {% endif %}>
      {%- for block in section.blocks -%}
        {%- liquid
          if block.settings.collection.url != blank
          assign tag = 'a'
          else
          assign tag = 'p'
          endif
      -%}
        <div class="yv-categories-content">
          <{{ tag }} {% if tag == 'a' %} href="{{ block.settings.collection.url }}" {% endif %} class="yv-categories-title text-center h6">{{ block.settings.category_title | default: block.settings.collection.title }}</{{ tag }}>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>
<style>
  #shopify-section-{{ section.id }}.shopify-section {
    --slide-count: {{ slide_count }};
    background:var(--{{- section.settings.bgcolor -}}ColorBody);
    padding-top:{{ section.settings.top_space_desktop }}px;
    padding-bottom:{{ section.settings.bottom_space_desktop }}px;
    {% if section.settings.enable_top_border %}
      border-top: 1px {{ section.settings.border_style }} var(--primaryBorderColor);
    {% endif %}
    {% if section.settings.enable_bottom_border %}
      border-bottom: 1px {{ section.settings.border_style }} var(--primaryBorderColor);
    {% endif %}
    {%- unless section.settings.bgcolor == 'primary' or section.settings.bgcolor == 'gradient' -%}
    --primaryColorBody:var(--{{- section.settings.bgcolor -}}ColorBody);
    --primaryBorderColor: var(--{{- section.settings.bgcolor -}}BorderColor);
    {%- endunless -%}
    {% if section.settings.highlight_text_gradient != blank %}
      --highlightTextColor: {{ section.settings.highlight_text_gradient }};
    {% else %}
      --highlightTextColor: {{ section.settings.highlight_text_color }};
    {% endif %}
  }

  #shopify-section-{{ section.id }}.shopify-section .heading-title {
    --fontSize: var(--{{ section.settings.heading_size }});
  }

  @media only screen and (max-width: 991px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --slide-count: 5;
    }
  }
  @media only screen and (max-width:575px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --slide-count: 3;
      padding-top:{{ section.settings.top_space_mobile }}px;
      padding-bottom:{{ section.settings.bottom_space_mobile }}px;
    }
  }

  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>
{% schema %}
{
  "name": "t:sections.categories.name",
  "tag": "section",
  "class": "categories-section",
  "settings": [ 
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:common.section_visibility.options.always.label",
          "value": "always"
        },
        {
          "label": "t:common.section_visibility.options.small_devices.label",
          "value": "small"
        },
        {
          "label": "t:common.section_visibility.options.large_devices.label",
          "value": "large"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:common.header.section_border.label"
    },
    {
      "type": "checkbox",
      "id": "enable_top_border",
      "label": "t:common.enable_top_border.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_bottom_border",
      "label": "t:common.enable_bottom_border.label",
      "default": false
    },
    {
      "type": "select",
      "id": "border_style",
      "default": "solid",
      "label": "t:common.border_style.label",
      "options": [
        {
          "value": "solid",
          "label": "t:common.border_style.options.solid.label"
        },
        {
          "value": "dashed",
          "label": "t:common.border_style.options.dashed.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:common.header.text_section.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Categories",
      "label": "t:sections.featured-collection.settings.heading.label",
      "info": "t:common.highlight_text_and_break_text.info"
    },
    {
      "type": "color",
      "id": "highlight_text_color",
      "label": "t:common.highlight_text_color.label",
      "default": "#000000",
      "visible_if": "{{ section.settings.heading contains '<strong>' or section.settings.heading contains '[' and section.settings.heading contains ']' }}"
    },
    {
      "type": "color_background",
      "id": "highlight_text_gradient",
      "label": "t:common.highlight_text_gradient.label",
      "info": "t:common.highlight_text_gradient.info",
      "default": "linear-gradient(90deg, #A678C8 0%, #718CC7 48.08%, #639A47 100%)",
      "visible_if": "{{ section.settings.heading contains '<strong>' or section.settings.heading contains '[' and section.settings.heading contains ']' }}"
    },
    {
      "type": "select",
      "id": "highlight_font",
      "default": "body",
      "label": "t:common.highlight_font.label",
      "options": [
        {
          "value": "body",
          "label": "t:common.highlight_font.options.body.label"
        },
        {
          "value": "heading",
          "label": "t:common.highlight_font.options.heading.label"
        },
        {
          "value": "accent",
          "label": "t:common.highlight_font.options.accent.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:common.header.heading_tag.label",
      "info": "t:common.header.heading_tag.info",
      "default": "h2",
      "options": [
        {
          "value": "h1",
          "label": "t:common.header.heading_tag.options.h1.label"
        },
        {
          "value": "h2",
          "label": "t:common.header.heading_tag.options.h2.label"
        },
        {
          "value": "h3",
          "label": "t:common.header.heading_tag.options.h3.label"
        },
        {
          "value": "h4",
          "label": "t:common.header.heading_tag.options.h4.label"
        },
        {
          "value": "h5",
          "label": "t:common.header.heading_tag.options.h5.label"
        },
        {
          "value": "h6",
          "label": "t:common.header.heading_tag.options.h6.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_size",
      "default": "h2",
      "label": "t:common.heading_size.label",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "text",
      "id": "subheading",
      "default": "Add Featured Collection here",
      "label": "t:sections.featured-collection.settings.subheading.label"
    },
    {
      "type": "header",
      "content": "t:common.header.color_section.label"
    },
    {
      "type": "select",
      "id": "bgcolor",
      "label": "t:common.header.background_section.label",
      "default": "gradient",
      "options": [
        {
          "value": "primary",
          "label": "t:common.header.primary.label"
        },
        {
          "value": "secondary",
          "label": "t:common.header.secondary.label"
        },
        {
          "value": "tertiary",
          "label": "t:common.header.tertiary.label"
        },
        {
          "value": "quaternary",
          "label": "t:common.header.quaternary.label"
        },
        {
          "value": "gradient",
          "label": "t:common.header.gradient.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:common.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:common.top_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:common.bottom_space_desktop.label",
      "default": 60,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:common.top_space_mobile.label",
      "default": 10,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:common.bottom_space_mobile.label",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "t:sections.banner-with-categories.blocks.categories.name",
      "limit": 10,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.main-list-collections.blocks.collection.settings.collection.label"
        },
        {
          "type": "text",
          "id": "category_title",
          "label": "t:sections.categories.category_title.label",
          "default": "Category",
          "info": "t:sections.categories.category_title.info"
        },
        {
          "type": "image_picker",
          "id": "category_image",
          "label": "t:sections.categories.category_image.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.categories.name",
      "category": "Collection",
      "blocks": [
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        }
      ]
    }
  ]
}
{% endschema %}
