            bodyParent.style.opacity = originalBodyOpacity;
            bodyParent.style.visibility = originalBodyVisibility;
            bodyElement.style.opacity = '';
            bodyElement.style.visibility = '';
            
            // Get button height to calculate total height
            const buttonElement = firstMobileItem.querySelector('button');
            const buttonHeight = buttonElement ? buttonElement.offsetHeight : 48;
            
            // Get container width for width (no max-width constraint on item)
            const wrapperWidth = mobileWrapper ? mobileWrapper.offsetWidth : window.innerWidth;
            
            // Apply total height and width
            const totalHeight = buttonHeight + bodyHeight;
            firstMobileItem.style.height = `${totalHeight}px`;
            firstMobileItem.style.width = `${wrapperWidth}px`;
          }
        }
      }

      // Add click listeners to content buttons
      Array.from(this.buttons).forEach(button => {
        button.addEventListener('click', () => {
          const buttonId = button.getAttribute('id');
          if (buttonId) {
            this.activateItem(buttonId);
          }
        });
      });
      
      // Add navigation buttons if they exist
      const navButtons = this.querySelectorAll('[data-action="previous"], [data-action="next"]');
      if (navButtons && navButtons.length > 0) {
        navButtons.forEach(navButton => {
          navButton.addEventListener('click', (e) => {
            e.preventDefault();
