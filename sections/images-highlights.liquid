          // Apply 100% max-width to body-inner (CSS handles it on mobile, no max-width on item)
          const bodyInner = targetItem.querySelector('.yv-images-highlights-body-inner');
          if (bodyInner) {
            bodyInner.style.maxWidth = '100%';
          }
        }
      }
      
      // Calculate exact translate position (negative because we're moving left)
      const translateX = -targetIndex * containerWidth;
      
      // Apply transform
      mobileWrapper.style.transform = `translateX(${translateX}px)`;
      
      // Update current index
      this.currentMobileIndex = targetIndex;
    }

