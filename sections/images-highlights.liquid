      if (action === 'next') {
        targetIndex = (this.currentMobileIndex + 1) % totalItems; // Loop to first if at end
      } else if (action === 'previous') {
        targetIndex = (this.currentMobileIndex - 1 + totalItems) % totalItems; // Loop to last if at start
      } else {
        return; // Invalid action
      }
      
      // Remove active class from current item (going out of view)
      const currentItem = mobileItems[this.currentMobileIndex];
      if (currentItem) {
        currentItem.classList.remove('active');
        // Reset height when item goes out of view
        currentItem.style.height = '';
      }
      
      // Add active class to target item (coming into view)
      const targetItem = mobileItems[targetIndex];
