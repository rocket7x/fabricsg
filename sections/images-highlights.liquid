          bodyParent.style.opacity = '1';
          bodyParent.style.visibility = 'visible';
          bodyElement.style.opacity = '1';
          bodyElement.style.visibility = 'visible';
          
          // Measure height
          const bodyHeight = bodyElement.scrollHeight;
          
          // Restore original styles
          bodyParent.style.position = originalBodyPosition;
          bodyParent.style.opacity = originalBodyOpacity;
          bodyParent.style.visibility = originalBodyVisibility;
