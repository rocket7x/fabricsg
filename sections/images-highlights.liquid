      if (!mobileWrapper) return;
      
      // Get all mobile items
      const mobileItems = this.querySelectorAll('[data-highlight-item-content-mobile]');
      if (!mobileItems || mobileItems.length === 0) return;
      
      const totalItems = mobileItems.length;
      
      // Get container width (each item is 100% width, no max-width constraint on item)
      const wrapperWidth = mobileWrapper.offsetWidth || window.innerWidth;
