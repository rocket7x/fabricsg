<div class="{{ section.settings.content_width }}">
  {% assign is_delimiter = false %}
  {% for block in section.blocks %}
    {%- case block.type -%}
      {% when 'column_delimiter' %}
        {% assign is_delimiter = true %}
    {% endcase %}
  {% endfor %}
  <div class="rich-text-content text-{{ section.settings.content_alignment }}">
    {% if is_delimiter %}
      <div class="hidden d-md-contents">
    {% endif %}
    <div class="richtext-content-inner" {{ block.shopify_attributes }}>
      {% for block in section.blocks %}
        {% if block.type == 'column_delimiter' %}
          </div>
          <div class="richtext-content-inner text-{{ section.settings.deliminter_content_alignment }}" {{ block.shopify_attributes }}>
            {% continue %}
        {% endif %}
        {% if block.type == 'richtext' or block.type == 'page' or block.type == 'button' or block.type == 'subheading' %}
          {% if block.settings.heading != blank or block.settings.page.title != blank %}
            <{{ block.settings.seo_heading }} class="content-heading {{ block.settings.size }}" id="{{ block.id }}">
              {%- if block.settings.page != blank and block.settings.heading == blank -%}
                {{ block.settings.page.title }}
              {%- else -%}
              {% if block.settings.highlight_font == 'body' %}
                {% capture highlightStyle %}
                <span class="body-font highlighted-text">
                {% endcapture %}
              {% elsif block.settings.highlight_font == 'heading' %}
              {% capture highlightStyle %}
                <span class="heading-font highlighted-text">
              {% endcapture %}  
              {% else %}
              {% capture highlightStyle %}
                <span class="accent-font highlighted-text">
              {% endcapture %}  
              {% endif %}

                {% comment %} {{ block.settings.heading | replace: "<strong>", highlightStyle | replace: "</strong>", '</span>' | replace: '++', '<br/>' }} {% endcomment %}

                {%- assign heading = block.settings.heading | replace: "<strong>", highlightStyle | replace: "</strong>", '</span>' | replace: '++', '<br/>' -%}
                {%- if heading contains '[' and heading contains ']' -%}
                  {%- render 'rotational-highlight', heading: heading -%}
                {%- else -%}
                  {{- heading -}}
                {%- endif -%}
              {%- endif -%}
            </{{ block.settings.seo_heading }}>
          {% endif %}
          {%- case block.type -%}
              {% when 'richtext' %}
                {%- if block.settings.content != blank -%}
                  <div class="rich-text-description rte">
                    {{ block.settings.content }}
                  </div>
                {%- endif -%}
              {% when 'page' %}
                <div class="rich-text-description rte">
                {% if block.settings.page != blank and block.settings.page.content != blank %}
                  {{ block.settings.page.content }}
                {% else %}
                  <p>{{ 'onboarding.rich_text_page' | t }}</p>
                {% endif %}
                </div>
              {%  when 'button' %}
                {%- if block.settings.btntext != blank and block.settings.btnlink != blank -%}
                  <div class="yv-richtext-button">
                    <a
                      class="button {{ block.settings.button_size }}-btn {{ block.settings.mobile_button_size }}-btn"
                      href="{{ block.settings.btnlink }}"
                    >
                      {% if settings.buttonAnimation == 'animated-arrow'%}
                        <span class="btn-animated-arrow"><svg fill="none" viewBox="0 0 8 8">
                          <path fill="currentColor" fill-rule="evenodd" d="M0 0h8v8H7V1.707L1.354 7.354 1 7.707.293 7l.353-.354L6.293 1H0V0Z" clip-rule="evenodd"></path>
                          </svg>
                        </span>
                      {% endif %}
                      <span class="btn-txt">{{- block.settings.btntext -}}</span>
                    </a>
                  </div>
                {%- endif -%}
              {% when 'subheading' %}
                {%- if block.settings.subheading != blank -%}
                <div class="yv-text-subheading text-medium heading-style">{{ block.settings.subheading }}</div>
                {%- endif -%}
          {%- endcase -%}
        {% endif %}
      {% endfor %} 
    </div>
    {% if is_delimiter %}
      </div>
    {% endif %}
    {% if is_delimiter == true %}
      <div class="d-md-none d-block">
        <div class="richtext-content-inner">
          {% for block in section.blocks %}
            {% if block.type == 'richtext' or block.type == 'page' or block.type == 'button' or block.type == 'subheading' %}
              {% if block.settings.heading != blank or block.settings.page.title != blank %}
                <{{ block.settings.seo_heading }} class="content-heading {{ block.settings.size }}" id="{{ block.id }}">
                  {%- if block.settings.page != blank and block.settings.heading == blank -%}
                    {{ block.settings.page.title }}
                  {%- else -%}
                  {% if block.settings.highlight_font == 'body' %}
                    {% capture highlightStyle %}
                    <span class="body-font highlighted-text">
                    {% endcapture %}
                  {% elsif block.settings.highlight_font == 'heading' %}
                  {% capture highlightStyle %}
                    <span class="heading-font highlighted-text">
                  {% endcapture %}  
                  {% else %}
                  {% capture highlightStyle %}
                    <span class="accent-font highlighted-text">
                  {% endcapture %}  
                  {% endif %}
                    {% comment %} {{ block.settings.heading | replace: "<strong>", highlightStyle | replace: "</strong>", '</span>' | replace: '++', '<br/>' }} {% endcomment %}

                    {%- assign heading = block.settings.heading | replace: "<strong>", highlightStyle | replace: "</strong>", '</span>' | replace: '++', '<br/>' -%}
                    {%- if heading contains '[' and heading contains ']' -%}
                      {%- render 'rotational-highlight', heading: heading -%}
                    {%- else -%}
                      {{- heading -}}
                    {%- endif -%}
                  {%- endif -%}
                </{{ block.settings.seo_heading }}>
              {% endif %}
              {%- case block.type -%}
                  {% when 'richtext' %}
                    {%- if block.settings.content != blank -%}
                      <div class="rich-text-description rte">
                        {{ block.settings.content }}
                      </div>
                    {%- endif -%}
                  {% when 'page' %}
                    <div class="rich-text-description rte">
                    {% if block.settings.page != blank and block.settings.page.content != blank %}
                      {{ block.settings.page.content }}
                    {% else %}
                      <p>{{ 'onboarding.rich_text_page' | t }}</p>
                    {% endif %}
                    </div>
                  {%  when 'button' %}
                    {%- if block.settings.btntext != blank and block.settings.btnlink != blank -%}
                      <a
                        class="button yv-collections-mainlink {{ block.settings.button_size }}-btn {{ block.settings.mobile_button_size }}-btn"
                        href="{{ block.settings.btnlink }}"
                      >
                        {% if settings.buttonAnimation == 'animated-arrow'%}
                          <span class="btn-animated-arrow"><svg fill="none" viewBox="0 0 8 8">
                            <path fill="currentColor" fill-rule="evenodd" d="M0 0h8v8H7V1.707L1.354 7.354 1 7.707.293 7l.353-.354L6.293 1H0V0Z" clip-rule="evenodd"></path>
                            </svg>
                          </span>
                        {% endif %}
                        <span class="btn-txt">{{- block.settings.btntext -}}</span>
                      </a>
                    {%- endif -%}
                  {% when 'subheading' %}
                    {%- if block.settings.subheading != blank -%}
                      <div class="yv-text-subheading text-medium heading-style">{{ block.settings.subheading }}</div>
                    {%- endif -%}
              {%- endcase -%}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</div>
<style>
  #shopify-section-{{ section.id }}.shopify-section {
    background:var(--{{- section.settings.bgcolor -}}ColorBody);
    padding-top:{{ section.settings.top_space_desktop }}px;
    padding-bottom:{{ section.settings.bottom_space_desktop }}px;
    {%- unless section.settings.bgcolor == 'primary' or section.settings.bgcolor == 'gradient' -%}
    --colorTextBody:var(--{{- section.settings.bgcolor -}}colorTextBody);
    --subheading_color:var(--{{- section.settings.bgcolor -}}_subheading_color);
    --colorLightTextBody:var(--{{- section.settings.bgcolor -}}ColorLightTextBody);
    --colorXlightTextBody:var(--{{- section.settings.bgcolor -}}ColorXlightTextBody);
    --heading_color:var(--{{- section.settings.bgcolor -}}_heading_color);
    {%- endunless -%}
  }

  {%- for block in section.blocks -%}
    {% case block.type %}
      {% when 'richtext' or 'page' %}
        #shopify-section-{{ section.id }} #{{ block.id }} {
          {% if block.settings.highlight_text_gradient != blank %}
            --highlightTextColor: {{ block.settings.highlight_text_gradient }};
          {% else %}
            --highlightTextColor: {{ block.settings.highlight_text_color }};
          {% endif %}
          --fontSize: var(--{{ block.settings.size }});
        }
      {% endcase %}
  {% endfor %}

  @media only screen and (max-width:991px) {
    #shopify-section-{{ section.id }}.shopify-section{
      padding-top:{{ section.settings.top_space_mobile }}px;
      padding-bottom:{{ section.settings.bottom_space_mobile }}px;
    }
  }
  {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
  {% endif %}
</style>
