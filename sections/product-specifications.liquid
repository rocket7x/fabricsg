{% render 'section-id-clipboard' %}
<div class="container sm-container">
  <div class="yv-product-specification-wrapper">
    {% if section.settings.heading != blank or section.settings.subheading != blank or section.settings.description != blank %}
      <div class="section-heading">
        {% if section.settings.subheading != blank %}
          <h6 class="section-heading-subtitle" data-aos="fade-up">  {{ section.settings.subheading }}</h6>
        {% endif %}
        {% if section.settings.heading != blank %}
          {% if section.settings.highlight_font == 'body' %}
            {% capture highlightStyle %}
              <span class="body-font highlighted-text">
            {% endcapture %}
          {% elsif section.settings.highlight_font == 'heading' %}
            {% capture highlightStyle %}
              <span class="heading-font highlighted-text">
            {% endcapture %}  
          {% else %}
            {% capture highlightStyle %}
              <span class="accent-font highlighted-text">
            {% endcapture %}  
          {% endif %}
         
          <{{ section.settings.seo_heading }} class="section-heading-title {{ section.settings.size }}" data-aos="fade-up">
          {%- assign heading = section.settings.heading | replace: "<strong>", highlightStyle | replace: "</strong>", '</span>' | replace: '++', '<br/>' -%}
          {%- if heading contains '[' and heading contains ']' -%}
            {%- render 'rotational-highlight', heading: heading -%}
          {%- else -%}
            {{- heading -}}
          {%- endif -%}
          </{{ section.settings.seo_heading }}>
        {% endif %}
        {% if section.settings.description != blank %}
          <div class="section-heading-desc" data-aos="fade-up">{{ section.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}
    {% if section.blocks.size > 0 %}
      <div class="yv-product-specification-list">
        {%- for block in section.blocks -%}
        <div class="yv-product-specification-item">
          <div class="yv-product-specification-icon">
            {%- render 'icons', icon: block.settings.icon -%}
          </div> 
          {% if block.settings.heading != blank or block.settings.description != blank %}
            <div class="yv-product-specification-content">
              <h6 class="yv-product-specification-title text-medium">{{ block.settings.heading }}</h6>
              <div class="yv-product-specification-description rte">{{ block.settings.content }}</div>
            </div>
          {% endif %}
        </div>
        {%- endfor -%}
      </div> 
    {% endif %}
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    background:var(--{{- section.settings.bgcolor -}}ColorBody);
    padding-top:{{ section.settings.top_space_desktop }}px;
    padding-bottom:{{ section.settings.bottom_space_desktop }}px;
    {%- unless section.settings.bgcolor == 'primary' or section.settings.bgcolor == 'gradient' -%}
    --colorTextBody:var(--{{- section.settings.bgcolor -}}colorTextBody);
    --subheading_color:var(--{{- section.settings.bgcolor -}}_subheading_color);
    --colorLightTextBody:var(--{{- section.settings.bgcolor -}}ColorLightTextBody);
    --colorXlightTextBody:var(--{{- section.settings.bgcolor -}}ColorXlightTextBody);
    --heading_color:var(--{{- section.settings.bgcolor -}}_heading_color);
    --primaryAlternateBg:var(--{{- section.settings.bgcolor -}}AlternateBg);
    --primaryCardBackground:var(--{{- section.settings.bgcolor -}}CardBackground);
    --primaryCardText:var(--{{- section.settings.bgcolor -}}CardText);
    {%- endunless -%}

    {% if section.settings.highlight_text_gradient != blank %}
      --highlightTextColor: {{ section.settings.highlight_text_gradient }};
    {% else %}
      --highlightTextColor: {{ section.settings.highlight_text_color }};
    {% endif %}
  }

  #shopify-section-{{ section.id }} .section-heading-title {
    --fontSize: var(--{{ section.settings.size }});
  }

  @media only screen and (max-width:991px) {
    #shopify-section-{{ section.id }}.shopify-section{
      padding-top:{{ section.settings.top_space_mobile }}px;
      padding-bottom:{{ section.settings.bottom_space_mobile }}px;
    }
  }  
  {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
  {% endif %}
</style>
{% schema %}
